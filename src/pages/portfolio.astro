---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio | Webresent">
  <main class="max-w-6xl 2xl:max-w-7xl mx-auto px-6 overflow-hidden">
    
    <!-- HEADER jako SECTION, přesně jako na HP -->
    <section id="hero" class="w-full flex flex-col justify-center relative z-10 py-12 lg:py-0">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center w-full">
        <!-- Left: Text -->
        <div class="flex flex-col items-start text-left fade-in-up">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-50 border border-blue-100 text-sm 2xl:text-base font-semibold text-blue-700 mb-8 2xl:mb-10">
            <span class="w-2 h-2 rounded-full bg-blue-600"></span>
            Ukázky práce
          </div>
          <h1 class="text-5xl sm:text-6xl md:text-7xl 2xl:text-[5.5rem] font-extrabold tracking-tighter text-zinc-900 leading-[0.95] mb-6 2xl:mb-8">
            Když se spojí <br/>
            <span class="text-blue-600">design a výkon.</span>
          </h1>
          <p class="text-lg md:text-xl 2xl:text-[1.25rem] text-zinc-600 mb-6 lg:mb-10 max-w-lg 2xl:max-w-xl leading-relaxed font-medium">
            Prohlédněte si weby, které nejen dobře vypadají, ale především plní svůj účel. Bleskové načítání, čistý kód a propracované SEO v praxi.
          </p>
        </div>

        <!-- Right: Abstract Visual -->
        <div class="flex relative w-full h-[280px] sm:h-[350px] lg:h-[400px] items-center justify-center group fade-in-up" style="animation-delay: 0.1s;">
          <div class="relative w-full max-w-[400px] aspect-square flex items-center justify-center transform scale-[0.8] sm:scale-90 lg:scale-100 mt-[-20px] lg:mt-0">
            <!-- Floating Card 1: Performance -->
            <div class="absolute top-[5%] right-[0%] lg:right-[5%] z-20 animate-float-delayed">
              <div class="w-44 lg:w-48 bg-white rounded-2xl p-3 lg:p-4 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.1)] border border-zinc-100 transform rotate-6 hover:rotate-0 hover:scale-105 transition-all duration-500 cursor-default">
                <div class="flex items-center gap-3 mb-3">
                  <div class="relative w-8 h-8 lg:w-10 lg:h-10 flex items-center justify-center">
                    <svg class="w-full h-full transform -rotate-90 text-green-500 drop-shadow-sm" viewBox="0 0 36 36">
                      <path stroke-dasharray="100, 100" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
                    </svg>
                    <span class="absolute text-green-600 font-bold text-[10px] lg:text-xs">100</span>
                  </div>
                  <div>
                    <div class="text-[11px] lg:text-xs font-bold text-zinc-900">Výkon webu</div>
                    <div class="text-[9px] lg:text-[10px] text-zinc-500">PageSpeed</div>
                  </div>
                </div>
                <div class="w-full h-1 lg:h-1.5 bg-zinc-100 rounded-full overflow-hidden">
                  <div class="w-full h-full bg-green-500"></div>
                </div>
              </div>
            </div>

            <!-- Floating Card 2: Code -->
            <div class="absolute bottom-[10%] lg:bottom-[5%] left-[0%] lg:left-[5%] z-10 animate-float">
              <div class="w-48 lg:w-56 bg-zinc-900 rounded-2xl p-4 lg:p-5 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.4)] border border-zinc-800 transform -rotate-3 hover:rotate-0 hover:scale-105 transition-all duration-500 cursor-default">
                <div class="flex gap-1.5 mb-3 lg:mb-4">
                  <div class="w-2 h-2 lg:w-2.5 lg:h-2.5 rounded-full bg-red-500/90"></div>
                  <div class="w-2 h-2 lg:w-2.5 lg:h-2.5 rounded-full bg-yellow-500/90"></div>
                  <div class="w-2 h-2 lg:w-2.5 lg:h-2.5 rounded-full bg-green-500/90"></div>
                </div>
                <div class="flex flex-col gap-2 lg:gap-2.5">
                  <div class="w-3/4 h-1.5 lg:h-2 bg-zinc-700 rounded-full"></div>
                  <div class="w-1/2 h-1.5 lg:h-2 bg-blue-500 rounded-full shadow-[0_0_8px_rgba(59,130,246,0.6)]"></div>
                  <div class="w-5/6 h-1.5 lg:h-2 bg-zinc-700 rounded-full"></div>
                  <div class="w-2/3 h-1.5 lg:h-2 bg-zinc-700 rounded-full mt-0.5 lg:mt-1"></div>
                </div>
              </div>
            </div>

            <!-- Floating Card 3: UI Design -->
            <div class="absolute top-[25%] left-[15%] lg:left-[20%] z-30 animate-float-slow">
              <div class="w-56 lg:w-64 bg-white/90 backdrop-blur-md rounded-2xl p-4 lg:p-5 shadow-[0_25px_50px_-12px_rgba(0,0,0,0.15)] border border-zinc-200/60 transform rotate-[-2deg] hover:rotate-0 hover:scale-105 transition-all duration-500 cursor-default">
                <div class="w-full h-24 lg:h-28 bg-zinc-50 border border-zinc-100 rounded-xl mb-3 lg:mb-4 overflow-hidden relative">
                  <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-600 to-blue-400"></div>
                  <!-- Mock UI element -->
                  <div class="absolute top-3 lg:top-4 left-3 lg:left-4 right-3 lg:right-4 flex justify-between items-center">
                    <div class="w-1/2 h-1.5 lg:h-2 bg-zinc-200 rounded-full"></div>
                    <div class="w-5 lg:w-6 h-1.5 lg:h-2 bg-zinc-200 rounded-full"></div>
                  </div>
                  <div class="absolute bottom-3 lg:bottom-4 left-3 lg:left-4 w-8 h-8 lg:w-10 lg:h-10 rounded-full bg-blue-50 border border-blue-100 flex items-center justify-center">
                    <div class="w-4 h-4 lg:w-5 lg:h-5 rounded-full bg-blue-600"></div>
                  </div>
                  <div class="absolute bottom-4 lg:bottom-5 left-14 lg:left-16 right-3 lg:right-4 flex flex-col gap-1 lg:gap-1.5">
                    <div class="w-full h-1.5 lg:h-2 bg-zinc-200 rounded-full"></div>
                    <div class="w-2/3 h-1.5 lg:h-2 bg-zinc-200 rounded-full"></div>
                  </div>
                </div>
                <div class="flex items-center justify-between">
                  <div class="flex flex-col gap-1 lg:gap-1.5 w-1/2">
                    <div class="w-full h-2 lg:h-2.5 bg-zinc-200 rounded-full"></div>
                    <div class="w-2/3 h-1.5 lg:h-2 bg-zinc-100 rounded-full"></div>
                  </div>
                  <div class="px-2.5 py-1 lg:px-3 bg-zinc-900 text-white text-[8px] lg:text-[9px] font-bold rounded-full uppercase tracking-wider">
                    Čistý design
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION DIVIDER -->
    <div class="w-full flex items-center justify-center pb-12 pt-6 lg:pb-16 lg:pt-8 2xl:pb-24 2xl:pt-12 scroll-reveal">
      <div class="h-px bg-zinc-200 w-full max-w-[80px] sm:max-w-[200px] 2xl:max-w-xs"></div>
      <div class="w-2 h-2 rounded-full bg-zinc-300 mx-4"></div>
      <div class="h-px bg-zinc-200 w-full max-w-[80px] sm:max-w-[200px] 2xl:max-w-xs"></div>
    </div>

    <!-- PROJECT 1: AMERICA POD VEZI (Removed bottom margin to fix gap before divider) -->
    <section class="mt-6 lg:mt-0 fade-in-up" style="animation-delay: 0.2s;">
      
      <div class="bg-white border border-zinc-200 rounded-[2rem] p-6 lg:p-10 2xl:p-12 shadow-sm hover:shadow-xl transition-all duration-500 flex flex-col xl:flex-row gap-10 lg:gap-16 items-center">

        <!-- TEXTOVÁ ČÁST -->
        <div class="w-full xl:w-[45%] flex flex-col items-start relative z-10 order-1 xl:order-1">

          <h2 class="text-3xl sm:text-4xl 2xl:text-5xl font-extrabold text-zinc-900 mb-6 tracking-tight">America Pod Věží</h2>

          <div class="flex flex-wrap gap-2 mb-6 sm:mb-8">
            <span class="px-3 py-1.5 bg-blue-50 text-blue-700 rounded-lg text-xs font-bold border border-blue-100">Web na míru</span>
            <span class="px-3 py-1.5 bg-blue-50 text-blue-700 rounded-lg text-xs font-bold border border-blue-100">Technické SEO</span>
            <span class="px-3 py-1.5 bg-blue-50 text-blue-700 rounded-lg text-xs font-bold border border-blue-100">Vlastní administrace</span>
          </div>

          <p class="text-zinc-600 text-base 2xl:text-lg mb-6 sm:mb-8 leading-relaxed font-medium">
            Kompletní záchrana a redesign webu oblíbené restaurace. Odstranil jsem masivní útok spamových botů, navrhl bleskový moderní design a implementoval automatické stahování denního menu, aby majitel ušetřil čas.
          </p>

          <div class="w-full border-l-[3px] border-blue-600 pl-4 mb-2 sm:mb-8 py-1">
            <p class="text-[11px] font-bold text-blue-600 uppercase tracking-wider mb-1.5">Výsledek</p>
            <p class="text-zinc-800 font-semibold text-base leading-relaxed">
              Stabilní pozice <strong class="text-zinc-900">#1 na Googlu</strong> na dotaz <em>„burger Mladá Boleslav“</em> a bezúdržbový chod.
            </p>
          </div>

          <div class="hidden sm:block">
            <a href="https://americapodvezi.cz" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-8 py-4 2xl:px-10 2xl:py-4 text-base 2xl:text-lg rounded-full bg-zinc-900 text-white font-bold text-center hover:bg-zinc-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-zinc-900 transition-all duration-300 hover:-translate-y-0.5 shadow-md justify-center group">
              Navštívit web
              <svg class="w-5 h-5 transform group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
            </a>
          </div>
        </div>

        <!-- OBRÁZKY -->
        <div class="w-full xl:w-[55%] relative flex flex-col items-start sm:items-center order-2 mt-4 xl:mt-0">
          <div class="relative w-full sm:w-[90%] pb-6 sm:pb-12 pt-2 mb-2 sm:mb-0">
            <div class="absolute inset-0 bg-blue-400/5 blur-3xl rounded-[3rem] -z-10"></div>
            <!-- Desktop -->
            <div class="w-[85%] rounded-xl shadow-[0_15px_30px_-10px_rgba(0,0,0,0.15)] border border-zinc-200/80 bg-white overflow-hidden flex flex-col transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_25px_50px_-12px_rgba(37,99,235,0.15)] relative z-10 group cursor-pointer">
              <div class="h-8 sm:h-10 bg-zinc-50 border-b border-zinc-200/80 flex items-center px-3 sm:px-4 gap-2 relative">
                <div class="flex gap-1.5 sm:gap-2">
                  <div class="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full bg-zinc-300"></div>
                  <div class="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full bg-zinc-300"></div>
                  <div class="w-2 h-2 sm:w-2.5 sm:h-2.5 rounded-full bg-zinc-300"></div>
                </div>
                <div class="absolute left-1/2 -translate-x-1/2 bg-white border border-zinc-200 rounded-md px-3 py-1 hidden sm:flex items-center gap-2 shadow-sm">
                  <svg class="w-3.5 h-3.5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                  <span class="text-[10px] text-zinc-600 font-medium">americapodvezi.cz</span>
                </div>
              </div>
              <div class="w-full aspect-[1842/923] bg-zinc-100 overflow-hidden relative">
                <img src="/images/america-pod-vezi-desktop.webp" alt="Desktop design" class="w-full h-full object-cover object-top" loading="lazy" />
              </div>
            </div>

            <!-- Mobil mockup -->
            <div class="w-[32%] sm:w-[28%] max-w-[180px] absolute right-0 sm:right-4 bottom-0 rounded-[1.2rem] sm:rounded-[2rem] shadow-[0_20px_40px_-10px_rgba(0,0,0,0.3)] border-[4px] sm:border-[8px] border-zinc-900 bg-zinc-900 overflow-hidden transition-all duration-500 hover:-translate-y-3 hover:scale-105 hover:shadow-[0_30px_60px_-15px_rgba(37,99,235,0.3)] z-20 cursor-pointer">
              <div class="w-full aspect-[944/2046] bg-zinc-100 overflow-hidden relative rounded-[0.8rem] sm:rounded-[1.4rem]">
                <img src="/images/america-pod-vezi-mobile.webp" alt="Mobilní design" class="w-full h-full object-cover object-top" loading="lazy" />
              </div>
            </div>
          </div>

          <div class="w-full sm:hidden mt-4">
            <a href="https://americapodvezi.cz" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-2 px-8 py-4 text-base rounded-full bg-zinc-900 text-white font-bold text-center active:bg-zinc-800 transition-all duration-300 shadow-md group w-full">
              Navštívit web
              <svg class="w-5 h-5 transform group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- SECTION DIVIDER -->
    <div class="w-full flex items-center justify-center py-12 lg:py-16 2xl:py-24 scroll-reveal">
      <div class="h-px bg-zinc-200 w-full max-w-[80px] sm:max-w-[200px] 2xl:max-w-xs"></div>
      <div class="w-2 h-2 rounded-full bg-zinc-300 mx-4"></div>
      <div class="h-px bg-zinc-200 w-full max-w-[80px] sm:max-w-[200px] 2xl:max-w-xs"></div>
    </div>

    <!-- CALL TO ACTION OR MORE PROJECTS (Odstraněna malá modrá linka, aby zůstal jen oddělovač) -->
    <section class="pb-16 lg:pb-24">
      <div class="flex flex-col items-center justify-center fade-in-up" style="animation-delay: 0.3s;">
        <h3 class="text-2xl md:text-3xl font-extrabold text-zinc-900 mb-4 text-center">Další projekty brzy</h3>
        <p class="text-zinc-500 font-medium text-center mb-8 max-w-md">Moje portfolio se neustále rozrůstá. Chcete být dalším úspěšným případem?</p>
        <a href="/objednavka" data-astro-prefetch class="px-8 py-4 rounded-full bg-blue-600 text-white font-bold text-lg hover:bg-blue-500 transition-all duration-300 hover:-translate-y-1 shadow-[0_10px_20px_rgba(37,99,235,0.2)] focus:outline-none focus:ring-4 focus:ring-blue-500/50">
          Poptat nezávazně web
        </a>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* Upraveno tak, aby Hero fungovalo bezpečně jako 100vh pomocí min-height a nepevnou height */
  #hero {
    min-height: unset;
  }
  @media (min-width: 1024px) {
    #hero {
      min-height: calc(100svh - 5rem);
    }
  }

  .fade-in-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Scroll reveal */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .scroll-reveal.active {
    opacity: 1;
    transform: translateY(0);
  }

  /* Animace pro levitující karty */
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
  }
  .animate-float {
    animation: float 6s ease-in-out infinite;
  }
  .animate-float-delayed {
    animation: float 6s ease-in-out 3s infinite;
  }
  .animate-float-slow {
    animation: float 8s ease-in-out 1s infinite;
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('active');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
  });
</script>
