<script>
  let typewriterTimer: ReturnType<typeof setTimeout> | null = null;

  document.addEventListener('astro:page-load', () => {

    const textElement = document.getElementById('typewriter-text');
    const wrapperElement = document.getElementById('typewriter-wrapper');

    if (typewriterTimer !== null) {
      clearTimeout(typewriterTimer);
      typewriterTimer = null;
    }

    if (textElement) {
      const phrases = [
        "tvorba prémiových webů na míru",
        "jak zvýšit prodeje z firemního webu",
        "profesionální webdesign a kódování",
        "bleskově rychlý web pro váš byznys",
      ];
      let phraseIndex = 0, charIndex = 0, isDeleting = false, typingSpeed = 80;

      function type() {
        if (!textElement) return;
        const currentPhrase = phrases[phraseIndex];
        textElement.textContent = currentPhrase.substring(0, isDeleting ? --charIndex : ++charIndex);
        if (wrapperElement) wrapperElement.scrollLeft = wrapperElement.scrollWidth;

        if (!isDeleting && charIndex === currentPhrase.length) {
          typingSpeed = 2500;
          isDeleting = true;
        } else if (isDeleting && charIndex === 0) {
          isDeleting = false;
          phraseIndex = (phraseIndex + 1) % phrases.length;
          typingSpeed = 500;
        } else {
          typingSpeed = isDeleting ? 30 : 80;
        }

        typewriterTimer = setTimeout(type, typingSpeed);
      }

      typewriterTimer = setTimeout(type, 1000);
    }

    const detailTimers = new Map<HTMLDetailsElement, ReturnType<typeof setTimeout>>();

    function openDetail(detail: HTMLDetailsElement) {
      if (detailTimers.has(detail)) {
        clearTimeout(detailTimers.get(detail)!);
        detailTimers.delete(detail);
      }
      const content = detail.querySelector<HTMLElement>(':scope > div');
      detail.setAttribute('open', '');
      if (!content) return;
      content.style.gridTemplateRows = '0fr';
      content.style.paddingBottom = '0';
      void content.offsetHeight;
      content.style.gridTemplateRows = '1fr';
      content.style.paddingBottom = '1.5rem';
      const timer = setTimeout(() => {
        content.style.gridTemplateRows = '';
        content.style.paddingBottom = '';
        detailTimers.delete(detail);
      }, 300);
      detailTimers.set(detail, timer);
    }

    function closeDetail(detail: HTMLDetailsElement) {
      if (detailTimers.has(detail)) {
        clearTimeout(detailTimers.get(detail)!);
        detailTimers.delete(detail);
      }
      const content = detail.querySelector<HTMLElement>(':scope > div');
      if (!content) { detail.removeAttribute('open'); return; }
      content.style.gridTemplateRows = '1fr';
      content.style.paddingBottom = '1.5rem';
      void content.offsetHeight;
      content.style.gridTemplateRows = '0fr';
      content.style.paddingBottom = '0';
      const timer = setTimeout(() => {
        detail.removeAttribute('open');
        content.style.gridTemplateRows = '';
        content.style.paddingBottom = '';
        detailTimers.delete(detail);
      }, 300);
      detailTimers.set(detail, timer);
    }

    const faqs = document.querySelectorAll<HTMLDetailsElement>('details');
    faqs.forEach(targetDetail => {
      const summary = targetDetail.querySelector('summary');
      summary?.addEventListener('click', (e) => {
        e.preventDefault();
        const isCurrentlyOpen = targetDetail.hasAttribute('open');
        faqs.forEach(detail => {
          if (detail !== targetDetail && detail.hasAttribute('open')) {
            closeDetail(detail);
          }
        });
        isCurrentlyOpen ? closeDetail(targetDetail) : openDetail(targetDetail);
      });
    });

    const cardsWrapper = document.getElementById('cards-wrapper');
    const cards = document.querySelectorAll<HTMLElement>('.spotlight-card');

    if (cardsWrapper && cards.length > 0) {
      cardsWrapper.addEventListener('mousemove', (e) => {
        cards.forEach(card => {
          const rect = card.getBoundingClientRect();
          card.style.setProperty('--mouse-x', `${(e as MouseEvent).clientX - rect.left}px`);
          card.style.setProperty('--mouse-y', `${(e as MouseEvent).clientY - rect.top}px`);
        });
      });
    }

  });
</script>