---
// src/pages/404.astro
import Layout from '../layouts/Layout.astro';
---

<!-- 
  OPRAVA: Původně bylo title="Stránka nenalezena | Webresent"
  Layout.astro přidává " | Webresent" automaticky, takže výsledek byl:
  "Stránka nenalezena | Webresent | Webresent"
  Nyní jen: "Stránka nenalezena | Webresent" ✓
-->
<Layout title="Stránka nenalezena">
  <main class="max-w-6xl 2xl:max-w-7xl mx-auto px-6 overflow-hidden flex flex-col items-center justify-center min-h-[65vh] lg:min-h-[75vh] text-center py-20 fade-in-up">

    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-zinc-100 border border-zinc-200 text-sm 2xl:text-base font-bold text-zinc-600 mb-6 2xl:mb-8 uppercase tracking-wider">
      <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></span>
      Chyba 404
    </div>

    <h1 class="text-8xl sm:text-9xl font-extrabold tracking-tighter text-zinc-900 leading-none mb-4 drop-shadow-sm">
      4<span class="text-blue-600">0</span>4
    </h1>

    <h2 class="text-3xl md:text-4xl 2xl:text-5xl font-extrabold text-zinc-900 tracking-tight mb-6">
      Tato stránka se někam zatoulala.
    </h2>

    <p class="text-lg md:text-xl text-zinc-600 max-w-xl mx-auto leading-relaxed font-medium mb-10">
      Omlouvám se, ale odkaz, na který jste klikli, už nefunguje, nebo byla stránka přesunuta. Pojďme to vzít zase od začátku.
    </p>

    <a href="/" data-astro-prefetch class="inline-flex items-center gap-2 px-8 py-4 2xl:px-10 2xl:py-4 text-base 2xl:text-lg rounded-full bg-zinc-900 text-white font-bold text-center hover:bg-zinc-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-zinc-900 transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 group">
      <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Zpět na hlavní stranu
    </a>

  </main>
</Layout>