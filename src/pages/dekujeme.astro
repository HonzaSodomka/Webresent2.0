---
// src/pages/dekujeme.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Poptávka přijata">
  <main class="max-w-6xl 2xl:max-w-7xl mx-auto px-6 overflow-hidden flex flex-col items-center justify-center min-h-[65vh] lg:min-h-[75vh] text-center py-20 fade-in-up">

    <div class="w-20 h-20 bg-green-50 border border-green-100 rounded-full flex items-center justify-center mb-8 shadow-sm">
      <div class="w-14 h-14 bg-green-500 rounded-full flex items-center justify-center text-white shadow-md">
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
    </div>

    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-green-50 border border-green-100 text-sm 2xl:text-base font-bold text-green-700 mb-6">
      <span class="w-2 h-2 rounded-full bg-green-500"></span>
      Poptávka dorazila
    </div>

    <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tighter text-zinc-900 leading-[1.0] mb-6 max-w-2xl">
      Díky, ozvu se<br />
      <span class="text-blue-600">do 24 hodin.</span>
    </h1>

    <p class="text-lg md:text-xl text-zinc-600 max-w-lg mx-auto leading-relaxed font-medium mb-4">
      Poptávku mám u sebe. Projdu ji a napíšu vám na zadaný e-mail — nebo zavolám, pokud jste uvedli telefon.
    </p>

    <p class="text-base text-zinc-500 max-w-md mx-auto leading-relaxed font-medium mb-10">
      Mezitím se klidně podívejte na <a href="/portfolio" class="text-blue-600 font-bold hover:underline">portfolio</a> nebo si přečtěte víc v <a href="/cenik" class="text-blue-600 font-bold hover:underline">ceníku</a>.
    </p>

    <div class="flex flex-col sm:flex-row gap-4">
      <a href="/" data-astro-prefetch class="inline-flex items-center gap-2 px-8 py-4 2xl:px-10 2xl:py-4 text-base 2xl:text-lg rounded-full bg-zinc-900 text-white font-bold text-center hover:bg-zinc-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-zinc-900 transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5 group">
        <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Zpět na hlavní stranu
      </a>
      <a href="/portfolio" data-astro-prefetch class="inline-flex items-center justify-center px-8 py-4 2xl:px-10 2xl:py-4 text-base 2xl:text-lg rounded-full bg-white border-2 border-zinc-200 text-zinc-900 font-bold text-center hover:border-zinc-300 hover:bg-zinc-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-zinc-200 transition-all duration-300 hover:-translate-y-0.5">
        Prohlédnout portfolio
      </a>
    </div>

  </main>
</Layout>