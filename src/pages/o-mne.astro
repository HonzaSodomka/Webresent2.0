---
import Layout from '../layouts/Layout.astro';
import Divider from '../components/Divider.astro';
---

<Layout title="O mně | Webresent">
  <main class="max-w-6xl 2xl:max-w-7xl mx-auto px-6 overflow-hidden">

    <!-- HERO -->
    <section id="hero" class="w-full flex flex-col justify-center relative z-10 py-12 lg:py-0">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center w-full">

        <!-- Levá strana: Text -->
        <div class="flex flex-col items-start text-left fade-in-up">
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-50 border border-blue-100 text-sm 2xl:text-base font-semibold text-blue-700 mb-8 2xl:mb-10">
            <span class="w-2 h-2 rounded-full bg-blue-600"></span>
            O mně
          </div>

          <h1 class="text-5xl sm:text-6xl md:text-7xl 2xl:text-[5.5rem] font-extrabold tracking-tighter text-zinc-900 leading-[0.95] mb-6 2xl:mb-8">
            Jsem Jan.<br />
            Stavím weby,<br />
            <span class="text-blue-600">které zaujmou.</span>
          </h1>

          <p class="text-lg md:text-xl 2xl:text-[1.25rem] text-zinc-600 mb-10 max-w-lg 2xl:max-w-xl leading-relaxed font-medium">
            Je mi 22 let, vyrostl jsem u Mladé Boleslavi a teď studuju na Technické univerzitě v Liberci. Weby dělám proto, že mě baví — a vidět, jak dobře navržený web skutečně funguje pro byznys klienta.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
            <a href="/portfolio" data-astro-prefetch class="px-8 py-4 2xl:px-10 2xl:py-4 text-base 2xl:text-lg rounded-full bg-zinc-900 text-white font-bold text-center hover:bg-zinc-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-zinc-900 transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
              Ukázky práce
            </a>
            <a href="/objednavka" data-astro-prefetch class="px-8 py-4 2xl:px-10 2xl:py-4 text-base 2xl:text-lg rounded-full bg-white border-2 border-zinc-200 text-zinc-900 font-bold text-center hover:border-zinc-300 hover:bg-zinc-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-zinc-200 transition-all duration-300 hover:-translate-y-0.5">
              Nezávazná poptávka
            </a>
          </div>
        </div>

        <!-- Pravá strana: Fotka -->
        <div class="flex items-center justify-center fade-in-up" style="animation-delay: 0.1s;">
          <div class="relative w-full max-w-[460px]">

            <!-- Jemný glow pod fotkou -->
            <div class="absolute -inset-4 bg-blue-500/5 blur-3xl rounded-[3rem] -z-10"></div>

            <!-- Fotka -->
            <div class="w-full rounded-[2rem] overflow-hidden border border-zinc-200 shadow-[0_25px_50px_-15px_rgba(0,0,0,0.12)] transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_30px_60px_-15px_rgba(37,99,235,0.12)]">
              <img
                src="/images/jan-sodomka.webp"
                alt="Jan Sodomka"
                class="w-full h-full object-cover object-top"
                loading="eager"
              />
            </div>

            <!-- Jmenovka dole -->
            <div class="absolute -bottom-5 left-6 right-6 bg-white border border-zinc-200 rounded-2xl px-5 py-3.5 shadow-[0_10px_30px_-10px_rgba(0,0,0,0.1)] flex items-center justify-between gap-4">
              <div>
                <p class="text-sm font-extrabold text-zinc-900 leading-tight">Bc. Jan Sodomka</p>
                <p class="text-xs font-semibold text-zinc-400 mt-0.5">Technická univerzita v Liberci</p>
              </div>
              <div class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
              </div>
            </div>

          </div>
        </div>

      </div>
    </section>

    <!-- Hero divider -->
    <div class="w-full flex items-center justify-center pb-12 lg:pb-16 2xl:pb-24 pt-14 lg:pt-6">
      <div class="h-px bg-zinc-200 w-full max-w-[80px] sm:max-w-[200px] 2xl:max-w-xs"></div>
      <div class="w-2 h-2 rounded-full bg-zinc-300 mx-4"></div>
      <div class="h-px bg-zinc-200 w-full max-w-[80px] sm:max-w-[200px] 2xl:max-w-xs"></div>
    </div>

  </main>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const hero = document.getElementById('hero');
    if (hero) {
      let lastWidth = window.innerWidth;
      const setHeroHeight = () => {
        hero.style.minHeight = `${window.innerHeight - 80}px`;
      };
      setHeroHeight();
      window.addEventListener('resize', () => {
        if (window.innerWidth !== lastWidth) {
          lastWidth = window.innerWidth;
          setHeroHeight();
        }
      });
      window.addEventListener('orientationchange', () => {
        setTimeout(setHeroHeight, 100);
      });
    }
  });
</script>
