---
import Layout from '../layouts/Layout.astro';
import Divider from '../components/Divider.astro';
---

<Layout
  title="Ceník tvorby webů — od 9 900 Kč | Webresent"
  description="Transparentní ceník tvorby webů na míru. Statický web od 9 900 Kč, firemní web s administrací od 19 900 Kč. Vždy pevná cena předem, bez překvapení."
>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type":"ListItem","position":1,"name":"Domů","item":"https://webresent.cz"},
    {"@type":"ListItem","position":2,"name":"Ceník","item":"https://webresent.cz/cenik"}
  ]
}
</script>

<div class="pg">

  <!-- HERO -->
  <section class="hero">
    <p class="hero__eye reveal">Transparentní ceník &mdash; 02</p>
    <h1 class="hero__h">
      <span class="line reveal" data-delay="0s">Ceník</span>
      <span class="line reveal" data-delay="0.08s">tvorby</span>
      <span class="line ital reveal" data-delay="0.16s">webů</span>
      <span class="line reveal" data-delay="0.22s">na míru.</span>
    </h1>
    <div class="hero__foot reveal" data-delay="0.3s">
      <p>Cena roste podle toho, co váš web reálně potřebuje.<br/>Po úvodní konzultaci dostanete vždy přesnou<br/>a finální nabídku šitou na míru vašemu byznysu.</p>
      <a href="/objednavka" class="hero__cta">Poptat web <span class="arr">→</span></a>
    </div>
  </section>

  <!-- TICKER -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker__t">
      <span>Statický web</span><span class="dot">/</span>
      <span>od 9 900 Kč</span><span class="dot">/</span>
      <span>Upravitelný web</span><span class="dot">/</span>
      <span>od 19 900 Kč</span><span class="dot">/</span>
      <span>E-shop & Aplikace</span><span class="dot">/</span>
      <span>Individuálně</span><span class="dot">/</span>
      <span>Pevná cena předem</span><span class="dot">/</span>
      <span>Návrh zdarma</span><span class="dot">/</span>
      <span>Statický web</span><span class="dot">/</span>
      <span>od 9 900 Kč</span><span class="dot">/</span>
      <span>Upravitelný web</span><span class="dot">/</span>
      <span>od 19 900 Kč</span><span class="dot">/</span>
      <span>E-shop & Aplikace</span><span class="dot">/</span>
      <span>Individuálně</span><span class="dot">/</span>
      <span>Pevná cena předem</span><span class="dot">/</span>
      <span>Návrh zdarma</span><span class="dot">/</span>
    </div>
  </div>

  <!-- PRICING CARDS -->
  <section class="cards">

    <div class="card reveal" data-delay="0s">
      <div class="card__top">
        <span class="card__n">01</span>
        <span class="card__tag">Základní</span>
      </div>
      <h2 class="card__name">Statický web</h2>
      <p class="card__desc">Ideální jako digitální vizitka podniku nebo pro prezentaci jedné služby. Bleskové načtítání, čistý kód, žádné zbytečné závislosti.</p>
      <ul class="card__ul">
        <li>Responzivní design na míru</li>
        <li>Kontaktní formulář</li>
        <li>Technické SEO & Search Console</li>
        <li>Nasazení na hosting</li>
        <li class="muted">Systém pro úpravu obsahu</li>
      </ul>
      <div class="card__price">
        <span class="card__from">od</span>
        <span class="card__amt">9 900</span>
        <span class="card__kc">Kč</span>
      </div>
      <a href="/objednavka?type=staticky" class="card__btn">Mám zájem <span class="arr">→</span></a>
    </div>

    <div class="card card--hi reveal" data-delay="0.08s">
      <div class="card__top">
        <span class="card__n">02</span>
        <span class="card__badge">Nejpopulárnější</span>
      </div>
      <h2 class="card__name">Upravitelný web</h2>
      <p class="card__desc">Zlatá střední cesta. Prezentace, kde si sami měníte texty i fotky &mdash; bez programování.</p>
      <ul class="card__ul">
        <li>Vše ze Statického webu</li>
        <li>Systém pro úpravu obsahu (CMS)</li>
        <li>Vícestránková architektura</li>
        <li>Pokročilá technická SEO příprava</li>
        <li>Možnost budoucího rozšíření</li>
      </ul>
      <div class="card__price">
        <span class="card__from">od</span>
        <span class="card__amt">19 900</span>
        <span class="card__kc">Kč</span>
      </div>
      <a href="/objednavka?type=upravitelny" class="card__btn">Chci web na míru <span class="arr">→</span></a>
    </div>

    <div class="card reveal" data-delay="0.16s">
      <div class="card__top">
        <span class="card__n">03</span>
        <span class="card__tag">Na míru</span>
      </div>
      <h2 class="card__name">Aplikace &amp; E&#8209;shop</h2>
      <p class="card__desc">Rozsáhlá řešení se složitou logikou, účty uživatelů nebo API napojeními. Komplexní projekty bez kompromisů.</p>
      <ul class="card__ul">
        <li>Napojení na platební brány</li>
        <li>Uživatelské účty & autentizace</li>
        <li>Automatizace procesů</li>
        <li>Filtrování a pokročilé funkce</li>
        <li>Integrace třetích stran (API)</li>
      </ul>
      <div class="card__price">
        <span class="card__amt card__amt--s">Individuálně</span>
      </div>
      <a href="/objednavka?type=aplikace" class="card__btn">Probrat projekt <span class="arr">→</span></a>
    </div>

  </section>

  <Divider label="Co ovlivňuje cenu" />

  <!-- CO URČUJE CENU -->
  <section class="factors">
    <div class="factors__hd reveal">
      <h2 class="factors__title">Co může<br/><em>ovlivnit</em><br/>finální cenu?</h2>
      <p class="factors__sub">Každý projekt je unikátní. Někdo potřebuje jen rychlou vizitku, jiný chce komplexní portál, který mu ušetří hodiny administrativy. Po konzultaci dostanete vždy přesnou nabídku — vždy vám řeknu rovinu.</p>
    </div>
    <dl class="factors__list">
      <div class="fl reveal" data-delay="0s">
        <dt>Počet unikátních podstránek</dt>
        <dd>Rozdíl mezi jednostránkovým webem a webem s blogem, ceníkem a případovkami.</dd>
      </div>
      <div class="fl reveal" data-delay="0.06s">
        <dt>Možnost upravovat obsah</dt>
        <dd>Zda potřebujete sami upravovat pouze články, nebo naprosto celou strukturu webu.</dd>
      </div>
      <div class="fl reveal" data-delay="0.12s">
        <dt>Jazykové mutace</dt>
        <dd>Příprava architektury pro přepínání jazyků (např. CZ&nbsp;/&nbsp;EN).</dd>
      </div>
      <div class="fl reveal" data-delay="0.18s">
        <dt>Specifické funkce</dt>
        <dd>Interaktivní mapy, pokročilé kalkulačky, nebo složitější rezervační formuláře.</dd>
      </div>
      <div class="fl reveal" data-delay="0.24s">
        <dt>Napojení třetích stran</dt>
        <dd>Integrace fakturačního systému (Fakturoid), automatizace e-mailů (Mailchimp) aj.</dd>
      </div>
      <div class="fl reveal" data-delay="0.30s">
        <dt>Dlouhodobá správa webu</dt>
        <dd>Zda web po dokončení předám do vašich rukou, nebo se o jeho chod a aktualizace budu starat já.</dd>
      </div>
    </dl>
  </section>

  <Divider label="Součást každého projektu" />

  <!-- RETAINER -->
  <section class="retainer reveal">
    <div class="retainer__l">
      <span class="retainer__tag">Volitelný doplňek</span>
      <h2 class="retainer__title">Dlouhodobá správa<br/>a údržba</h2>
      <p class="retainer__desc">Vy se staráte o byznys, já o to, aby web bezchybně běžel. Neřešíte výpadky, bezpečnostní rizika ani technické problémy. Vše běží u mě na serveru a vy máte klid.</p>
      <ul class="retainer__ul">
        <li>Rychlý hosting na mém serveru</li>
        <li>Bezpečnostní aktualizace</li>
        <li>Aktivní hlídání dostupnosti</li>
        <li>Podpora při problémech</li>
      </ul>
    </div>
    <div class="retainer__r">
      <span class="retainer__label">Měsíční paušál</span>
      <span class="retainer__price">Individuálně</span>
      <p class="retainer__note">*Cena se odvíjí od velikosti webu, náročnosti na server a rozsahu podpory.</p>
      <a href="/objednavka?type=sprava" class="retainer__btn">Zeptat se <span class="arr">→</span></a>
    </div>
  </section>

  <Divider label="Standard vždy" />

  <!-- INCLUDED -->
  <section class="inc">
    <h2 class="inc__h reveal">Co je zahrnuto<br/><em>v každém webu.</em></h2>
    <p class="inc__sub reveal" data-delay="0.1s">Āť už stavíme jednoduchou vizitku nebo e-shop &mdash; pod kapotou to šlápe na 100&nbsp;%. Tohle je standard každého mého projektu.</p>
    <ul class="inc__g">
      <li class="ig reveal" data-delay="0s">
        <span class="ig__n">01</span>
        <h3>Bleskové načtítání</h3>
        <p>Žádné pomalé WordPress šablony s tisícem pluginů. Píšu čistý kód, takže se váš web načte dřív, než zákazník stihne mrknout.</p>
      </li>
      <li class="ig reveal" data-delay="0.07s">
        <span class="ig__n">02</span>
        <h3>Plná responzivita</h3>
        <p>Většina uživatelů si vaši službu hledá na mobilu cestou v tramvaji. Váš web bude vypadat a fungovat bezchybně na každém displeji.</p>
      </li>
      <li class="ig reveal" data-delay="0.14s">
        <span class="ig__n">03</span>
        <h3>Technické SEO</h3>
        <p>Nasazení správných titulků, strukturovaná data a napojení do Google Search Console. Vyhledávače vás najdou.</p>
      </li>
      <li class="ig reveal" data-delay="0.21s">
        <span class="ig__n">04</span>
        <h3>Texty v ceně</h3>
        <p>Píšu texty sám. Není třeba přinášet vlastní copy &mdash; texty které prodávají jsou součástí každého projektu.</p>
      </li>
      <li class="ig reveal" data-delay="0.28s">
        <span class="ig__n">05</span>
        <h3>Nasazení & hosting</h3>
        <p>Dodám hotový web nasazený na rychlém serveru. Není třeba řešit nic dalšího &mdash; web je hned v životu.</p>
      </li>
      <li class="ig reveal" data-delay="0.35s">
        <span class="ig__n">06</span>
        <h3>Pevná cena</h3>
        <p>Co se domluvime, to zaplatite. Žádné příplatky za složitost, příjem návrš nebo skryté položky.</p>
      </li>
    </ul>
  </section>

  <Divider />

  <!-- CTA -->
  <section class="cta">
    <p class="cta__e reveal">Nejste si jistí, co přesně potřebujete?</p>
    <h2 class="cta__h reveal" data-delay="0.1s">Ozvěte<br/><em>se mi.</em></h2>
    <p class="cta__sub reveal" data-delay="0.18s">Probereme váš byznys a najdeme řešení. Podívejte se také na <a href="/portfolio">ukázky hotových webů</a>.</p>
    <a href="/objednavka?type=konzultace" class="cta__btn reveal" data-delay="0.26s">
      Poptat nezávazně web <span class="arr">→</span>
    </a>
  </section>

</div>
</Layout>

<style>
.pg { max-width: 1400px; margin: 0 auto; padding: 0 2.5rem; }

/* HERO */
.hero { padding: 8rem 0 6rem; border-bottom: 1px solid var(--line); }
.hero__eye {
  font-size: .7rem; font-weight: 600; letter-spacing: .18em; text-transform: uppercase;
  color: var(--white-3); margin-bottom: 3rem;
}
.hero__h {
  display: flex; flex-wrap: wrap; gap: .06em;
  font-size: clamp(5rem, 13vw, 13rem);
  font-weight: 800; line-height: .92; letter-spacing: -.04em;
  color: var(--white); margin-bottom: 4rem;
}
.line { display: block; }
.ital { font-style: italic; color: var(--white-2); }
.hero__foot {
  display: flex; align-items: flex-start; justify-content: space-between;
  gap: 3rem; flex-wrap: wrap;
}
.hero__foot p { font-size: 1rem; color: var(--white-2); line-height: 1.7; max-width: 420px; }
.hero__cta {
  flex-shrink: 0;
  font-size: .78rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
  color: var(--bg); background: var(--white);
  text-decoration: none; padding: .9rem 2rem;
  display: inline-flex; align-items: center; gap: .6rem;
  transition: opacity .2s; white-space: nowrap;
}
.hero__cta:hover { opacity: .75; }

/* TICKER */
.ticker {
  overflow: hidden; border-bottom: 1px solid var(--line);
  padding: 1rem 0; margin: 0 -2.5rem; background: var(--bg-2);
}
.ticker__t {
  display: inline-flex; gap: 2rem; white-space: nowrap;
  animation: tick 30s linear infinite;
  font-size: .68rem; font-weight: 600; letter-spacing: .14em; text-transform: uppercase;
  color: var(--white-3);
}
.dot { opacity: .3; }
@keyframes tick { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* CARDS */
.cards {
  display: grid; grid-template-columns: repeat(3, 1fr);
  gap: 1px; background: var(--line);
  border: 1px solid var(--line);
  margin: 0 -2.5rem;
}
.card {
  background: var(--bg);
  padding: 3rem 2.5rem;
  display: flex; flex-direction: column; gap: 0;
  transition: background .25s;
}
.card:hover { background: var(--bg-2); }
.card--hi { background: var(--bg-3); }
.card--hi:hover { background: #202020; }

.card__top {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 2rem;
}
.card__n {
  font-size: .65rem; font-weight: 700; letter-spacing: .14em; color: var(--white-3);
}
.card__tag {
  font-size: .62rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase;
  color: var(--white-3); border: 1px solid var(--line); padding: .2rem .6rem;
}
.card__badge {
  font-size: .62rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
  color: var(--white); border: 1px solid var(--white-3); padding: .2rem .6rem;
}
.card__name {
  font-size: 1.6rem; font-weight: 700; letter-spacing: -.025em; line-height: 1.1;
  color: var(--white); margin-bottom: 1rem;
}
.card__desc {
  font-size: .88rem; color: var(--white-2); line-height: 1.65;
  margin-bottom: 1.5rem;
}
.card__ul {
  list-style: none; padding: 0; margin-bottom: 2rem; flex: 1;
  display: flex; flex-direction: column; gap: .5rem;
}
.card__ul li {
  font-size: .82rem; color: var(--white-2); padding-left: 1.2rem; position: relative;
}
.card__ul li::before { content: '—'; position: absolute; left: 0; color: var(--white-3); }
.card__ul li.muted { color: var(--white-3); text-decoration: line-through; }
.card__price {
  margin-bottom: 2rem; padding-top: 2rem; border-top: 1px solid var(--line);
}
.card__from { display: block; font-size: .68rem; color: var(--white-3); margin-bottom: .15rem; }
.card__amt {
  display: block; font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 800; letter-spacing: -.04em; line-height: 1; color: var(--white);
}
.card__amt--s { font-size: 1.6rem; }
.card__kc { display: block; font-size: .75rem; color: var(--white-3); margin-top: .2rem; }
.card__btn {
  display: inline-flex; align-items: center; gap: .5rem; align-self: flex-start;
  font-size: .72rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
  color: var(--white); text-decoration: none;
  border: 1px solid var(--white-3); padding: .7rem 1.4rem;
  transition: border-color .2s, color .2s;
}
.card__btn:hover { border-color: var(--white); }

/* FACTORS */
.factors { display: grid; grid-template-columns: 1fr 2fr; gap: 8rem; align-items: start; }
.factors__title {
  font-size: clamp(2.2rem, 4vw, 3.5rem); font-weight: 800;
  letter-spacing: -.035em; line-height: .95;
  color: var(--white); margin-bottom: 1.5rem;
}
.factors__title em { font-style: italic; color: var(--white-2); }
.factors__sub { font-size: .9rem; color: var(--white-2); line-height: 1.7; }
.factors__list { display: flex; flex-direction: column; }
.fl {
  display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;
  padding: 1.5rem 0; border-bottom: 1px solid var(--line); align-items: baseline;
}
.fl:first-child { border-top: 1px solid var(--line); }
.fl dt { font-size: .9rem; font-weight: 700; color: var(--white); letter-spacing: -.01em; }
.fl dd { font-size: .85rem; color: var(--white-2); line-height: 1.6; }

/* RETAINER */
.retainer {
  display: grid; grid-template-columns: 2fr 1fr; gap: 6rem;
  align-items: start;
  padding: 3.5rem;
  border: 1px solid var(--line);
  background: var(--bg-2);
}
.retainer__tag {
  display: inline-block;
  font-size: .62rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase;
  color: var(--white-3); border: 1px solid var(--line); padding: .2rem .7rem;
  margin-bottom: 1.5rem;
}
.retainer__title {
  font-size: clamp(1.8rem, 3.5vw, 2.8rem); font-weight: 800;
  letter-spacing: -.03em; line-height: 1; color: var(--white); margin-bottom: 1.2rem;
}
.retainer__desc { font-size: .9rem; color: var(--white-2); line-height: 1.7; margin-bottom: 1.5rem; }
.retainer__ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: .5rem; }
.retainer__ul li { font-size: .85rem; color: var(--white-2); padding-left: 1.2rem; position: relative; }
.retainer__ul li::before { content: '—'; position: absolute; left: 0; color: var(--white-3); }
.retainer__label { display: block; font-size: .68rem; color: var(--white-3); letter-spacing: .08em; margin-bottom: .5rem; }
.retainer__price {
  display: block; font-size: 2rem; font-weight: 800; letter-spacing: -.04em;
  color: var(--white); margin-bottom: 1rem;
}
.retainer__note { font-size: .75rem; color: var(--white-3); line-height: 1.5; margin-bottom: 1.5rem; }
.retainer__btn {
  display: inline-flex; align-items: center; gap: .5rem;
  font-size: .72rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
  color: var(--white); text-decoration: none;
  border: 1px solid var(--white-3); padding: .7rem 1.4rem;
  transition: border-color .2s;
}
.retainer__btn:hover { border-color: var(--white); }

/* INCLUDED */
.inc { }
.inc__h {
  font-size: clamp(2.5rem, 6vw, 5rem); font-weight: 800;
  letter-spacing: -.04em; line-height: .92; color: var(--white);
  margin-bottom: 1.5rem;
}
.inc__h em { font-style: italic; color: var(--white-2); }
.inc__sub { font-size: 1rem; color: var(--white-2); line-height: 1.65; max-width: 560px; margin-bottom: 4rem; }
.inc__g {
  list-style: none; padding: 0;
  display: grid; grid-template-columns: repeat(3, 1fr);
  border-top: 1px solid var(--line); border-left: 1px solid var(--line);
}
.ig {
  padding: 2.5rem 2rem; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line);
  transition: background .2s;
}
.ig:hover { background: var(--bg-2); }
.ig__n {
  display: block; font-size: .65rem; font-weight: 700; letter-spacing: .14em;
  color: var(--white-3); margin-bottom: 1rem;
}
.ig h3 { font-size: .95rem; font-weight: 700; color: var(--white); margin-bottom: .5rem; letter-spacing: -.01em; }
.ig p { font-size: .83rem; color: var(--white-2); line-height: 1.65; }

/* CTA */
.cta { padding: 10rem 0; text-align: center; }
.cta__e {
  font-size: .7rem; font-weight: 600; letter-spacing: .18em; text-transform: uppercase;
  color: var(--white-3); margin-bottom: 1.5rem;
}
.cta__h {
  font-size: clamp(5rem, 14vw, 12rem); font-weight: 800;
  letter-spacing: -.05em; line-height: .88;
  color: var(--white); margin-bottom: 1.5rem;
}
.cta__h em { font-style: italic; color: var(--white-2); }
.cta__sub {
  font-size: .95rem; color: var(--white-2); margin-bottom: 3rem; line-height: 1.6;
}
.cta__sub a { color: var(--white); text-decoration: underline; text-underline-offset: 3px; }
.cta__btn {
  display: inline-flex; align-items: center; gap: .75rem;
  font-size: .78rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
  color: var(--bg); background: var(--white);
  text-decoration: none; padding: 1.1rem 2.5rem;
  transition: opacity .2s;
}
.cta__btn:hover { opacity: .75; }

.arr { transition: transform .25s; display: inline-block; }
a:hover .arr { transform: translateX(5px); }

/* RESPONSIVE */
@media (max-width: 1100px) {
  .cards { grid-template-columns: 1fr; margin: 0; }
  .factors { grid-template-columns: 1fr; gap: 3rem; }
  .retainer { grid-template-columns: 1fr; gap: 3rem; }
  .inc__g { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 768px) {
  .inc__g { grid-template-columns: 1fr; }
  .fl { grid-template-columns: 1fr; gap: .4rem; }
}
@media (max-width: 640px) {
  .pg { padding: 0 1.5rem; }
  .hero { padding: 5rem 0 4rem; }
  .hero__h { font-size: clamp(3.5rem, 16vw, 6rem); }
  .ticker { margin: 0 -1.5rem; }
  .cta { padding: 6rem 0; }
  .retainer { padding: 2rem 1.5rem; }
}
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => {
        if (e.isIntersecting) {
          const el = e.target as HTMLElement;
          el.style.transitionDelay = el.dataset.delay || '0s';
          el.classList.add('is-visible');
          io.unobserve(el);
        }
      }),
      { threshold: 0.07 }
    );
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
  });
</script>
