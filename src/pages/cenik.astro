---
import Layout from '../layouts/Layout.astro';
import Divider from '../components/Divider.astro';
---

<Layout title="Ceník | Webresent" description="Transparentní ceník tvorby webů na míru. Statický web od 9 900 Kč, firemní web s administrací od 19 900 Kč. Vždy pevná cena předem, bez překvapení.">
  <main class="max-w-6xl 2xl:max-w-7xl mx-auto px-6 overflow-hidden">
    
    <!-- HERO SECTION -->
    <section class="w-full flex flex-col items-center justify-center text-center pt-24 pb-16 lg:pt-32 lg:pb-24 fade-in-up">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-50 border border-blue-100 text-sm 2xl:text-base font-semibold text-blue-700 mb-6 2xl:mb-8">
        <span class="w-2 h-2 rounded-full bg-blue-600"></span>
        Transparentní ceník
      </div>
      <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold tracking-tighter text-zinc-900 leading-[0.95] mb-6 2xl:mb-8 max-w-4xl">
        Investice, která se <br class="hidden sm:block" />
        <span class="text-blue-600">skutečně vrátí.</span>
      </h1>
      <p class="text-lg md:text-xl 2xl:text-[1.25rem] text-zinc-600 max-w-2xl leading-relaxed font-medium">
        Cena roste podle toho, co váš web reálně potřebuje. Po úvodní konzultaci dostanete vždy přesnou a finální nabídku šitou na míru vašemu byznysu.
      </p>
    </section>

    <!-- PRICING CARDS -->
    <section class="relative w-full max-w-5xl mx-auto">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg h-full max-h-[500px] bg-blue-600/10 blur-[100px] rounded-full z-0 pointer-events-none"></div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 items-center relative z-10">

        <!-- KARTA 1: Statický web / Landing Page -->
        <div class="bg-white border border-zinc-200 rounded-[2rem] p-8 shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-500 fade-in-up flex flex-col h-full" style="animation-delay: 0.1s;">
          <h3 class="text-xl lg:text-2xl font-bold text-zinc-900 mb-2">Statický web</h3>
          <p class="text-zinc-500 text-sm mb-6 h-auto min-h-[40px]">Ideální jako digitální vizitka podniku nebo pro prezentaci jedné služby.</p>
          <div class="mb-6 flex items-end">
            <span class="text-zinc-400 font-medium mr-1 mb-1">od</span>
            <span class="text-3xl lg:text-4xl font-extrabold text-zinc-900">9 900</span>
            <span class="text-zinc-500 font-medium mb-1"> Kč</span>
          </div>
          <ul class="flex flex-col gap-4 mb-8 flex-1">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-600 text-sm font-medium">Bleskové načítání kódu</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-600 text-sm font-medium">Moderní a čistý design</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-600 text-sm font-medium">Základní kontaktní formulář</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-zinc-300 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
              <span class="text-zinc-400 text-sm font-medium line-through">Systém pro úpravu obsahu</span>
            </li>
          </ul>
          <a href="/objednavka?type=staticky" data-astro-prefetch class="w-full py-3.5 rounded-full bg-zinc-50 border border-zinc-200 text-zinc-900 font-bold text-center hover:bg-zinc-100 hover:border-zinc-300 transition-all mt-auto focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-zinc-200">
            Mám zájem
          </a>
        </div>

        <!-- KARTA 2: Firemní web s administrací (Zvýrazněná, tmavá) -->
        <div class="bg-zinc-900 border border-zinc-800 rounded-[2rem] p-8 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.5)] lg:scale-105 hover:-translate-y-2 lg:hover:scale-[1.07] transition-all duration-500 fade-in-up flex flex-col h-full relative overflow-hidden" style="animation-delay: 0.2s;">
          <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-blue-600 to-blue-400"></div>
          
          <div class="inline-flex self-start px-2.5 py-1 bg-blue-500/10 border border-blue-500/20 text-blue-400 text-[10px] font-bold rounded-md uppercase tracking-wider mb-4">
            Nejčastější volba
          </div>
          <h3 class="text-2xl lg:text-3xl font-bold text-white mb-2">Upravitelný web</h3>
          <p class="text-zinc-400 text-sm mb-6 h-auto min-h-[40px]">Zlatá střední cesta. Prezentace, kde si sami měníte texty i fotky.</p>
          <div class="mb-6 flex items-end">
            <span class="text-zinc-400 font-medium mr-1 mb-1">od</span>
            <span class="text-4xl lg:text-5xl font-extrabold text-white">19 900</span>
            <span class="text-zinc-400 font-medium mb-1"> Kč</span>
          </div>
          <ul class="flex flex-col gap-4 mb-8 flex-1">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-200 text-sm font-medium">Jednoduchá editace webu</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-200 text-sm font-medium">Vícestánková struktura</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-200 text-sm font-medium">Pokročilá technická SEO příprava</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-200 text-sm font-medium">Možnost budoucího rozšíření</span>
            </li>
          </ul>
          <a href="/objednavka?type=upravitelny" data-astro-prefetch class="w-full py-4 rounded-full bg-blue-600 text-white font-bold text-center hover:bg-blue-500 hover:shadow-[0_0_20px_rgba(37,99,235,0.4)] transition-all mt-auto transform hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-zinc-900 focus:ring-offset-zinc-900">
            Chci web na míru
          </a>
        </div>

        <!-- KARTA 3: E-shop / Aplikace -->
        <div class="bg-white border border-zinc-200 rounded-[2rem] p-8 shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-500 fade-in-up flex flex-col h-full" style="animation-delay: 0.3s;">
          <h3 class="text-xl lg:text-2xl font-bold text-zinc-900 mb-2">Aplikace & E-shop</h3>
          <p class="text-zinc-500 text-sm mb-6 h-auto min-h-[40px]">Rozsáhlá řešení se složitou logikou, účty uživatelů nebo API napojeními.</p>
          <div class="mb-6 flex items-end h-[40px] lg:h-[48px]">
            <span class="text-3xl lg:text-4xl font-extrabold text-zinc-900">Individuálně</span>
          </div>
          <ul class="flex flex-col gap-4 mb-8 flex-1">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-600 text-sm font-medium">Napojení na platební brány</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-600 text-sm font-medium">Automatizace procesů</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-600 text-sm font-medium">Filtrování a pokročilé funkce</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-600 text-sm font-medium">Integrace třetích stran (API)</span>
            </li>
          </ul>
          <a href="/objednavka?type=aplikace" data-astro-prefetch class="w-full py-3.5 rounded-full bg-zinc-50 border border-zinc-200 text-zinc-900 font-bold text-center hover:bg-zinc-100 hover:border-zinc-300 transition-all mt-auto focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-zinc-200">
            Probrat projekt
          </a>
        </div>

      </div>
    </section>

    <Divider />

    <!-- CO URČUJE CENU? -->
    <section class="max-w-5xl mx-auto fade-in-up" style="animation-delay: 0.3s;">
      <div class="bg-zinc-50 border border-zinc-200 rounded-[2rem] p-8 lg:p-12">
        <h2 class="text-2xl md:text-3xl font-extrabold text-zinc-900 mb-6">Co může ovlivnit finální cenu webu?</h2>
        <p class="text-zinc-600 mb-8 max-w-3xl leading-relaxed">
          Každý projekt je unikátní. Někdo potřebuje jen rychlou vizitku, jiný chce komplexní portál, který mu ušetří hodiny administrativy. Zde jsou nejčastější prvky, které do tvorby ceny vstupují:
        </p>
        
        <div class="grid md:grid-cols-2 gap-x-12 gap-y-6">
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
              </div>
              <div>
                <strong class="text-zinc-900 block text-sm mb-1">Počet unikátních podstránek</strong>
                <span class="text-zinc-600 text-sm">Rozdíl mezi jednostránkovým webem a webem s blogem, ceníkem a případovkami.</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
              </div>
              <div>
                <strong class="text-zinc-900 block text-sm mb-1">Možnost upravovat obsah</strong>
                <span class="text-zinc-600 text-sm">Zda potřebujete sami upravovat pouze články, nebo naprosto celou strukturu webu.</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
              </div>
              <div>
                <strong class="text-zinc-900 block text-sm mb-1">Jazykové mutace</strong>
                <span class="text-zinc-600 text-sm">Příprava architektury pro přepínání jazyků (např. CZ / EN).</span>
              </div>
            </li>
          </ul>
          
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
              </div>
              <div>
                <strong class="text-zinc-900 block text-sm mb-1">Specifické funkce</strong>
                <span class="text-zinc-600 text-sm">Interaktivní mapy, pokročilé kalkulačky, nebo složitější rezervační formuláře.</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
              </div>
              <div>
                <strong class="text-zinc-900 block text-sm mb-1">Napojení třetích stran</strong>
                <span class="text-zinc-600 text-sm">Integrace fakturačního systému (Fakturoid), automatizace e-mailů (Mailchimp) aj.</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-6 h-6 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path></svg>
              </div>
              <div>
                <strong class="text-zinc-900 block text-sm mb-1">Dlouhodobá správa webu</strong>
                <span class="text-zinc-600 text-sm">Zda web po dokončení předám do vašich rukou, nebo se o jeho chod a aktualizace budu starat já.</span>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <Divider />

    <!-- MĚSÍČNÍ SPRÁVA (RETAINER) -->
    <section class="max-w-5xl mx-auto fade-in-up" style="animation-delay: 0.4s;">
      <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 items-center bg-white border border-blue-200 rounded-[2rem] p-8 lg:p-10 shadow-[0_15px_40px_-15px_rgba(37,99,235,0.1)] relative overflow-hidden">
        <div class="absolute -right-20 -top-20 w-64 h-64 bg-blue-50 rounded-full blur-3xl -z-10"></div>
        
        <div class="w-full lg:w-2/3">
          <div class="inline-flex items-center gap-2 px-2.5 py-1 bg-blue-50 border border-blue-100 text-[10px] font-bold text-blue-600 rounded-md uppercase tracking-wider mb-4">
            Volitelný doplněk
          </div>
          <h2 class="text-2xl md:text-3xl font-extrabold text-zinc-900 mb-4">Dlouhodobá správa a údržba</h2>
          <p class="text-zinc-600 mb-6 leading-relaxed">
            Vy se staráte o byznys, já o to, aby web bezchybně běžel. Neřešíte výpadky, bezpečnostní rizika ani technické problémy. Vše běží u mě na serveru a vy máte klid.
          </p>
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full bg-blue-500"></div>
              <span class="text-sm font-medium text-zinc-700">Rychlý hosting na mém serveru</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full bg-blue-500"></div>
              <span class="text-sm font-medium text-zinc-700">Bezpečnostní aktualizace</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full bg-blue-500"></div>
              <span class="text-sm font-medium text-zinc-700">Aktivní hlídání dostupnosti</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full bg-blue-500"></div>
              <span class="text-sm font-medium text-zinc-700">Podpora při problémech</span>
            </div>
          </div>
        </div>
        
        <div class="w-full lg:w-1/3 flex flex-col items-start lg:items-center justify-center p-6 bg-zinc-50 border border-zinc-200 rounded-2xl relative z-10">
          <span class="text-zinc-500 text-sm font-medium mb-1">Měsíční paušál</span>
          <div class="flex items-end mb-4">
            <span class="text-2xl lg:text-3xl font-extrabold text-zinc-900">Individuálně</span>
          </div>
          <p class="text-xs text-zinc-500 text-left lg:text-center leading-relaxed">
            *Cena se odvíjí od velikosti webu, náročnosti na server a rozsahu podpory.
          </p>
        </div>
      </div>
    </section>

    <Divider />

    <!-- WHAT'S INCLUDED SECTION -->
    <section class="max-w-5xl mx-auto">
      <div class="text-center mb-12 fade-in-up" style="animation-delay: 0.5s;">
        <h2 class="text-3xl md:text-4xl font-extrabold text-zinc-900 mb-4 tracking-tight">Co je zahrnuto v každém webu?</h2>
        <p class="text-lg text-zinc-600 max-w-2xl mx-auto">Ať už stavíme jednoduchou vizitku nebo e-shop, pod kapotou to šlape na 100&nbsp;%. Tohle je standard každého mého projektu.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        <div class="bg-zinc-50 border border-zinc-200 rounded-3xl p-8 fade-in-up hover:border-zinc-300 hover:shadow-md transition-all duration-300" style="animation-delay: 0.6s;">
          <div class="w-12 h-12 bg-blue-50 rounded-xl border border-blue-100 shadow-sm flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <h3 class="text-lg font-bold text-zinc-900 mb-2">Bleskové načítání</h3>
          <p class="text-zinc-600 text-sm leading-relaxed">Žádné pomalé WordPress šablony s tisícem pluginů. Píšu čistý kód, takže se váš web načte dřív, než zákazník stihne mrknout.</p>
        </div>
        
        <div class="bg-zinc-50 border border-zinc-200 rounded-3xl p-8 fade-in-up hover:border-zinc-300 hover:shadow-md transition-all duration-300" style="animation-delay: 0.7s;">
          <div class="w-12 h-12 bg-blue-50 rounded-xl border border-blue-100 shadow-sm flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 00-2-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="text-lg font-bold text-zinc-900 mb-2">Plná responzivita</h3>
          <p class="text-zinc-600 text-sm leading-relaxed">Většina uživatelů si vaši službu hledá na mobilu cestou v tramvaji. Váš web bude vypadat a fungovat bezchybně na každém displeji.</p>
        </div>

        <div class="bg-zinc-50 border border-zinc-200 rounded-3xl p-8 fade-in-up hover:border-zinc-300 hover:shadow-md transition-all duration-300" style="animation-delay: 0.8s;">
          <div class="w-12 h-12 bg-blue-50 rounded-xl border border-blue-100 shadow-sm flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
          </div>
          <h3 class="text-lg font-bold text-zinc-900 mb-2">Základní viditelnost</h3>
          <p class="text-zinc-600 text-sm leading-relaxed">Nasazení správných titulků a napojení do Google Search Console, aby o vás vyhledávače věděly a klienti vás mohli najít podle jména.</p>
        </div>
      </div>
    </section>

    <Divider />

    <!-- BOTTOM CTA -->
    <section class="pb-16 lg:pb-24">
      <div class="flex flex-col items-center justify-center fade-in-up" style="animation-delay: 0.9s;">
        <h3 class="text-2xl md:text-3xl font-extrabold text-zinc-900 mb-4 text-center">Nejste si jistí, co přesně potřebujete?</h3>
