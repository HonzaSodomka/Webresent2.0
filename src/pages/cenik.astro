---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ceník | Webresent">
  <main class="max-w-6xl 2xl:max-w-7xl mx-auto px-6 overflow-hidden">
    
    <!-- HERO SECTION -->
    <section class="w-full flex flex-col items-center justify-center text-center pt-24 pb-16 lg:pt-32 lg:pb-24 fade-in-up">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-50 border border-blue-100 text-sm 2xl:text-base font-semibold text-blue-700 mb-6 2xl:mb-8">
        <span class="w-2 h-2 rounded-full bg-blue-600"></span>
        Transparentní ceník
      </div>
      <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold tracking-tighter text-zinc-900 leading-[0.95] mb-6 2xl:mb-8 max-w-4xl">
        Investice, která se <br class="hidden sm:block" />
        <span class="text-blue-600">skutečně vrátí.</span>
      </h1>
      <p class="text-lg md:text-xl 2xl:text-[1.25rem] text-zinc-600 max-w-2xl leading-relaxed font-medium">
        Nestavím weby jako výdaj, ale jako vašeho nejlepšího obchodního zástupce. Ceny jsou orientační, každý projekt naceňuji přesně podle vašich obchodních cílů.
      </p>
    </section>

    <!-- PRICING CARDS -->
    <section class="relative w-full max-w-5xl mx-auto mb-24 lg:mb-32">
      <!-- Background Glow pro prostřední kartu -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg h-full max-h-[500px] bg-blue-600/10 blur-[100px] rounded-full z-0 pointer-events-none"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 items-center relative z-10">

        <!-- KARTA 1: Landing Page -->
        <div class="bg-white border border-zinc-200 rounded-[2rem] p-8 shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-500 fade-in-up flex flex-col h-full" style="animation-delay: 0.1s;">
          <h3 class="text-xl lg:text-2xl font-bold text-zinc-900 mb-2">Landing Page</h3>
          <p class="text-zinc-500 text-sm mb-6 h-auto min-h-[40px]">Ideální pro prezentaci jedné služby, události nebo produktu.</p>
          <div class="mb-6">
            <span class="text-3xl lg:text-4xl font-extrabold text-zinc-900">15 000</span>
            <span class="text-zinc-500 font-medium"> Kč</span>
          </div>
          <ul class="flex flex-col gap-4 mb-8 flex-1">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-600 text-sm font-medium">Jednostránkový unikátní design</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-600 text-sm font-medium">Optimalizace pro konverze</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-600 text-sm font-medium">Kontaktní formulář</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-zinc-300 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
              <span class="text-zinc-400 text-sm font-medium line-through">Vlastní administrace (CMS)</span>
            </li>
          </ul>
          <a href="/objednavka" data-astro-prefetch class="w-full py-3.5 rounded-full bg-zinc-50 border border-zinc-200 text-zinc-900 font-bold text-center hover:bg-zinc-100 hover:border-zinc-300 transition-all mt-auto focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-zinc-200">
            Mám zájem
          </a>
        </div>

        <!-- KARTA 2: Firemní web (Zvýrazněná, tmavá) -->
        <div class="bg-zinc-900 border border-zinc-800 rounded-[2rem] p-8 shadow-[0_20px_40px_-15px_rgba(0,0,0,0.5)] lg:scale-105 hover:-translate-y-2 lg:hover:scale-[1.07] transition-all duration-500 fade-in-up flex flex-col h-full relative overflow-hidden md:col-span-2 lg:col-span-1" style="animation-delay: 0.2s;">
          <!-- Subtle blue accent line top -->
          <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-blue-600 to-blue-400"></div>
          
          <div class="inline-flex self-start px-2.5 py-1 bg-blue-500/10 border border-blue-500/20 text-blue-400 text-[10px] font-bold rounded-md uppercase tracking-wider mb-4">
            Nejčastější volba
          </div>
          <h3 class="text-2xl lg:text-3xl font-bold text-white mb-2">Firemní web</h3>
          <p class="text-zinc-400 text-sm mb-6 h-auto min-h-[40px]">Kompletní vícestránková prezentace s vlastním systémem pro úpravu obsahu.</p>
          <div class="mb-6">
            <span class="text-zinc-400 font-medium mr-1">od</span>
            <span class="text-4xl lg:text-5xl font-extrabold text-white">30 000</span>
            <span class="text-zinc-400 font-medium"> Kč</span>
          </div>
          <ul class="flex flex-col gap-4 mb-8 flex-1">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-200 text-sm font-medium">Až 5 podstránek na míru</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-200 text-sm font-medium">Vlastní administrace (CMS)</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-200 text-sm font-medium">Pokročilá SEO struktura</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-200 text-sm font-medium">Sekce Blog / Aktuality</span>
            </li>
          </ul>
          <a href="/objednavka" data-astro-prefetch class="w-full py-4 rounded-full bg-blue-600 text-white font-bold text-center hover:bg-blue-500 hover:shadow-[0_0_20px_rgba(37,99,235,0.4)] transition-all mt-auto transform hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-zinc-900 focus:ring-offset-zinc-900">
            Chci firemní web
          </a>
        </div>

        <!-- KARTA 3: E-shop / Aplikace -->
        <div class="bg-white border border-zinc-200 rounded-[2rem] p-8 shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-500 fade-in-up flex flex-col h-full md:col-span-1" style="animation-delay: 0.3s;">
          <h3 class="text-xl lg:text-2xl font-bold text-zinc-900 mb-2">Aplikace & E-shop</h3>
          <p class="text-zinc-500 text-sm mb-6 h-auto min-h-[40px]">Rozsáhlá řešení na míru se složitou databázovou logikou a napojeními.</p>
          <div class="mb-6 flex items-end h-[40px] lg:h-[48px]">
            <span class="text-3xl lg:text-4xl font-extrabold text-zinc-900">Individuálně</span>
          </div>
          <ul class="flex flex-col gap-4 mb-8 flex-1">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-600 text-sm font-medium">Napojení na platební brány</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-600 text-sm font-medium">Architektura pro velkou zátěž</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-600 text-sm font-medium">Filtrování a pokročilé funkce</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-600 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>
              <span class="text-zinc-600 text-sm font-medium">Integrace třetích stran (API)</span>
            </li>
          </ul>
          <a href="/objednavka" data-astro-prefetch class="w-full py-3.5 rounded-full bg-zinc-50 border border-zinc-200 text-zinc-900 font-bold text-center hover:bg-zinc-100 hover:border-zinc-300 transition-all mt-auto focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-zinc-200">
            Probrat projekt
          </a>
        </div>

      </div>
    </section>

    <!-- WHAT'S INCLUDED SECTION -->
    <section class="max-w-5xl mx-auto mb-24 lg:mb-32">
      <div class="text-center mb-12 fade-in-up" style="animation-delay: 0.4s;">
        <h2 class="text-3xl md:text-4xl font-extrabold text-zinc-900 mb-4 tracking-tight">Co je zahrnuto v každém webu?</h2>
        <p class="text-lg text-zinc-600 max-w-2xl mx-auto">Ať už stavíme jednoduchou vizitku nebo e-shop, pod kapotou to šlape na 100 %. Tohle je standard každého mého projektu.</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        <!-- Box 1 -->
        <div class="bg-zinc-50 border border-zinc-200 rounded-3xl p-8 fade-in-up hover:border-zinc-300 hover:shadow-md transition-all duration-300" style="animation-delay: 0.5s;">
          <div class="w-12 h-12 bg-white rounded-xl border border-zinc-200 shadow-sm flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-zinc-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <h3 class="text-lg font-bold text-zinc-900 mb-2">Technické SEO a rychlost</h3>
          <p class="text-zinc-600 text-sm leading-relaxed">Web se načte do vteřiny a Google ho bude milovat. Nastavím správnou sémantiku, meta tagy i sitemapu pro špičkové pozice.</p>
        </div>
        
        <!-- Box 2 -->
        <div class="bg-zinc-50 border border-zinc-200 rounded-3xl p-8 fade-in-up hover:border-zinc-300 hover:shadow-md transition-all duration-300" style="animation-delay: 0.6s;">
          <div class="w-12 h-12 bg-white rounded-xl border border-zinc-200 shadow-sm flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-zinc-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
          </div>
          <h3 class="text-lg font-bold text-zinc-900 mb-2">Plná responzivita</h3>
          <p class="text-zinc-600 text-sm leading-relaxed">Většina uživatelů dnes nakupuje a prohlíží na mobilech. Váš web bude vypadat a fungovat bezchybně na každém displeji.</p>
        </div>

        <!-- Box 3 -->
        <div class="bg-zinc-50 border border-zinc-200 rounded-3xl p-8 fade-in-up hover:border-zinc-300 hover:shadow-md transition-all duration-300" style="animation-delay: 0.7s;">
          <div class="w-12 h-12 bg-white rounded-xl border border-zinc-200 shadow-sm flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-zinc-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
          </div>
          <h3 class="text-lg font-bold text-zinc-900 mb-2">Analytika a měření</h3>
          <p class="text-zinc-600 text-sm leading-relaxed">Nasadím Google Analytics 4 a propojím web se Search Console. Budete mít dokonalý přehled o návštěvnosti a chování zákazníků.</p>
        </div>
      </div>
    </section>

    <!-- BOTTOM CTA -->
    <section class="pb-16 lg:pb-24 pt-4">
      <div class="flex flex-col items-center justify-center fade-in-up" style="animation-delay: 0.8s;">
        <div class="w-16 h-1 bg-zinc-200 rounded-full mb-6"></div>
        <h3 class="text-2xl font-extrabold text-zinc-900 mb-3 text-center">Nejste si jistí, co potřebujete?</h3>
        <p class="text-zinc-500 font-medium text-center mb-8 max-w-md">Napište mi. Zjistíme, kde vás tlačí bota a najdeme řešení, které bude dávat byznysový smysl.</p>
        <a href="/objednavka" data-astro-prefetch class="px-8 py-3.5 rounded-full bg-white border-2 border-zinc-200 text-zinc-900 font-bold text-center hover:border-zinc-300 hover:bg-zinc-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-zinc-200 transition-all duration-300 hover:-translate-y-0.5">
          Konzultace zdarma
        </a>
      </div>
    </section>

  </main>
</Layout>

<style>
  .fade-in-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }
</style>
