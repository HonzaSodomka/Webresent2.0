---
import Layout from '../layouts/Layout.astro';
import Divider from '../components/Divider.astro';
---

<Layout
  title="Ceník | Webresent"
  description="Transparentní ceník tvorby webů na míru. Statický web od 9 900 Kč, upravitelný od 19 900 Kč."
>
<div class="pg">

  <!-- HERO -->
  <section class="hero">
    <p class="hero__eye reveal">Ceník &mdash; 02</p>
    <h1 class="hero__h">
      <span class="reveal" data-delay="0s">Kolik</span>
      <span class="reveal" data-delay="0.08s">stál</span>
      <span class="reveal ital" data-delay="0.16s">dobrý</span>
      <span class="reveal" data-delay="0.24s">web?</span>
    </h1>
    <div class="hero__foot reveal" data-delay="0.3s">
      <p>Pevná cena předem.<br/>Vždy.</p>
      <a href="/objednavka" class="hero__cta">Poptat web <span class="arr">→</span></a>
    </div>
  </section>

  <!-- TICKER -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker__t">
      <span>Statický web</span><span class="dot">/</span>
      <span>od 9 900 Kč</span><span class="dot">/</span>
      <span>Upravitelný web</span><span class="dot">/</span>
      <span>od 19 900 Kč</span><span class="dot">/</span>
      <span>E-shop & Aplikace</span><span class="dot">/</span>
      <span>Individuálně</span><span class="dot">/</span>
      <span>Statický web</span><span class="dot">/</span>
      <span>od 9 900 Kč</span><span class="dot">/</span>
      <span>Upravitelný web</span><span class="dot">/</span>
      <span>od 19 900 Kč</span><span class="dot">/</span>
      <span>E-shop & Aplikace</span><span class="dot">/</span>
      <span>Individuálně</span><span class="dot">/</span>
    </div>
  </div>

  <!-- PRICING -->
  <section class="pricing">

    <article class="pr reveal" data-delay="0s">
      <div class="pr__l">
        <span class="pr__n">01</span>
        <div>
          <h2 class="pr__name">Statický<br/>web</h2>
          <p class="pr__tag">Základní</p>
        </div>
      </div>
      <div class="pr__mid">
        <p class="pr__desc">Digitální vizitka nebo prezentace jedné služby. Bleskové načtítání, čistý kód, žádné zbytečné závislosti.</p>
        <ul class="pr__ul">
          <li>Responzivní design na míru</li>
          <li>Kontaktní formulář</li>
          <li>Technické SEO & Search Console</li>
          <li>Nasazení na hosting</li>
        </ul>
      </div>
      <div class="pr__r">
        <div class="pr__price">
          <span class="pr__from">od</span>
          <span class="pr__amt">9 900</span>
          <span class="pr__kc">Kč</span>
        </div>
        <a href="/objednavka?type=staticky" class="pr__btn">Poptat <span class="arr">→</span></a>
      </div>
    </article>

    <article class="pr pr--hi reveal" data-delay="0.06s">
      <div class="pr__l">
        <span class="pr__n">02</span>
        <div>
          <h2 class="pr__name">Upravitelný<br/>web</h2>
          <p class="pr__tag">Nejpopulárnější</p>
        </div>
      </div>
      <div class="pr__mid">
        <p class="pr__desc">Vícestránková prezentace s CMS. Měníte texty a fotky sami &mdash; bez programování.</p>
        <ul class="pr__ul">
          <li>Vše ze Statického webu</li>
          <li>Systém pro úpravu obsahu</li>
          <li>Vícestránková architektura</li>
          <li>Pokročilá SEO příprava</li>
          <li>Možnost budoucího rozšíření</li>
        </ul>
      </div>
      <div class="pr__r">
        <div class="pr__price">
          <span class="pr__from">od</span>
          <span class="pr__amt">19 900</span>
          <span class="pr__kc">Kč</span>
        </div>
        <a href="/objednavka?type=upravitelny" class="pr__btn">Poptat <span class="arr">→</span></a>
      </div>
    </article>

    <article class="pr reveal" data-delay="0.12s">
      <div class="pr__l">
        <span class="pr__n">03</span>
        <div>
          <h2 class="pr__name">Aplikace &amp;<br/>E&#8209;shop</h2>
          <p class="pr__tag">Na míru</p>
        </div>
      </div>
      <div class="pr__mid">
        <p class="pr__desc">E-shopy, rezervační systémy, uživatelské portály. Komplexní řešení bez kompromisů.</p>
        <ul class="pr__ul">
          <li>Platební brány & e-commerce</li>
          <li>Uživatelské účty & autentizace</li>
          <li>API integrace</li>
          <li>Pokročilé funkce na míru</li>
        </ul>
      </div>
      <div class="pr__r">
        <div class="pr__price">
          <span class="pr__amt pr__amt--s">Individuálně</span>
        </div>
        <a href="/objednavka?type=aplikace" class="pr__btn">Probrat <span class="arr">→</span></a>
      </div>
    </article>

  </section>

  <Divider label="Vždy součástí" />

  <!-- INCLUDED -->
  <section class="inc">
    <h2 class="inc__h reveal">V&nbsp;každém<br/>projektu.</h2>
    <ul class="inc__g">
      <li class="ig reveal" data-delay="0s"><span class="ig__n">01</span><h3>Bleskové načtítání</h3><p>Žádný WordPress. Čistý kód který se načte dřív než klient stihne mrknout.</p></li>
      <li class="ig reveal" data-delay="0.07s"><span class="ig__n">02</span><h3>Plná responzivita</h3><p>Bezchybný vzhled na každém zařízení — mobil, tablet, 4K.</p></li>
      <li class="ig reveal" data-delay="0.14s"><span class="ig__n">03</span><h3>Technické SEO</h3><p>Strukturovaná data, napojeni do Search Console. Vyhledávače vás najdou.</p></li>
      <li class="ig reveal" data-delay="0.21s"><span class="ig__n">04</span><h3>Texty v ceně</h3><p>Píšu texty sám. Není třeba přinášet vlastní copy.</p></li>
      <li class="ig reveal" data-delay="0.28s"><span class="ig__n">05</span><h3>Nasazení & hosting</h3><p>Web nasazený na rychlém serveru. Není třeba řešit nic dalšího.</p></li>
      <li class="ig reveal" data-delay="0.35s"><span class="ig__n">06</span><h3>Pevná cena</h3><p>Co se domluvime, to zaplatite. Žádné příplatky, překvapení nebo skryté položky.</p></li>
    </ul>
  </section>

  <Divider />

  <!-- CTA -->
  <section class="cta">
    <p class="cta__e reveal">Nejste si jistí co potřebujete?</p>
    <h2 class="cta__h reveal" data-delay="0.1s">Napíšeme<br/><em>si.</em></h2>
    <a href="/objednavka?type=konzultace" class="cta__btn reveal" data-delay="0.2s">
      Nezávazná konzultace <span class="arr">→</span>
    </a>
  </section>

</div>
</Layout>

<style>
.pg { max-width: 1400px; margin: 0 auto; padding: 0 2.5rem; }

/* HERO */
.hero { padding: 8rem 0 6rem; border-bottom: 1px solid var(--line); }
.hero__eye {
  font-size: .7rem; font-weight: 600; letter-spacing: .18em; text-transform: uppercase;
  color: var(--white-3); margin-bottom: 3rem;
}
.hero__h {
  display: flex; flex-wrap: wrap; gap: .08em;
  font-size: clamp(5rem, 13vw, 13rem);
  font-weight: 800; line-height: .92; letter-spacing: -.04em;
  color: var(--white); margin-bottom: 4rem;
}
.hero__h .ital { font-style: italic; color: var(--white-2); }
.hero__foot {
  display: flex; align-items: center; justify-content: space-between;
  gap: 2rem; flex-wrap: wrap;
}
.hero__foot p { font-size: 1rem; color: var(--white-2); line-height: 1.5; }
.hero__cta {
  font-size: .78rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
  color: var(--bg); background: var(--white);
  text-decoration: none; padding: .9rem 2rem;
  display: inline-flex; align-items: center; gap: .6rem;
  transition: opacity .2s;
}
.hero__cta:hover { opacity: .75; }

/* TICKER */
.ticker {
  overflow: hidden; border-bottom: 1px solid var(--line);
  padding: 1rem 0; margin: 0 -2.5rem; background: var(--bg-2);
}
.ticker__t {
  display: inline-flex; gap: 2rem; white-space: nowrap;
  animation: tick 30s linear infinite;
  font-size: .68rem; font-weight: 600; letter-spacing: .14em; text-transform: uppercase;
  color: var(--white-3);
}
.dot { color: var(--white-3); opacity: .4; }
@keyframes tick { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* PRICING */
.pricing { padding: 0; }
.pr {
  display: grid; grid-template-columns: 12rem 1fr auto;
  gap: 3rem; align-items: center;
  padding: 3.5rem 0; border-bottom: 1px solid var(--line);
  transition: background .2s;
}
.pr:hover { background: var(--bg-2); margin: 0 -2.5rem; padding-left: 2.5rem; padding-right: 2.5rem; }
.pr--hi { background: var(--bg-3); margin: 0 -2.5rem; padding-left: 2.5rem; padding-right: 2.5rem; }
.pr--hi:hover { background: #202020; }

.pr__l { display: flex; align-items: flex-start; gap: 1.5rem; }
.pr__n {
  font-size: .68rem; font-weight: 700; letter-spacing: .12em;
  color: var(--white-3); padding-top: .35rem; flex-shrink: 0;
}
.pr__name {
  font-size: 1.5rem; font-weight: 700; letter-spacing: -.025em; line-height: 1.1;
  color: var(--white); margin-bottom: .35rem;
}
.pr__tag {
  font-size: .65rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase;
  color: var(--white-3);
}
.pr__desc { font-size: .9rem; color: var(--white-2); line-height: 1.6; margin-bottom: 1rem; max-width: 400px; }
.pr__ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: .3rem; }
.pr__ul li { font-size: .82rem; color: var(--white-3); padding-left: 1rem; position: relative; }
.pr__ul li::before { content: '—'; position: absolute; left: 0; }

.pr__r { text-align: right; }
.pr__price { margin-bottom: 1.5rem; }
.pr__from { display: block; font-size: .68rem; color: var(--white-3); letter-spacing: .05em; margin-bottom: .15rem; }
.pr__amt {
  display: block; font-size: clamp(2.2rem, 4vw, 3.2rem);
  font-weight: 800; letter-spacing: -.04em; line-height: 1; color: var(--white);
}
.pr__amt--s { font-size: 1.4rem; letter-spacing: -.02em; }
.pr__kc { display: block; font-size: .75rem; color: var(--white-3); margin-top: .2rem; }
.pr__btn {
  display: inline-flex; align-items: center; gap: .5rem;
  font-size: .72rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
  color: var(--white); text-decoration: none;
  border: 1px solid var(--white-3); padding: .65rem 1.4rem;
  transition: border-color .2s, color .2s;
  white-space: nowrap;
}
.pr__btn:hover { border-color: var(--white); color: var(--white); }

/* INCLUDED */
.inc { display: grid; grid-template-columns: 1fr 2fr; gap: 8rem; align-items: start; }
.inc__h {
  font-size: clamp(2.5rem, 5vw, 4.5rem); font-weight: 800;
  letter-spacing: -.04em; line-height: .95; color: var(--white);
  position: sticky; top: 96px;
}
.inc__g {
  list-style: none; padding: 0;
  display: grid; grid-template-columns: 1fr 1fr; gap: 0;
}
.ig {
  padding: 2.5rem 2rem 2.5rem 0; border-bottom: 1px solid var(--line);
}
.ig:nth-child(even) { padding-left: 2rem; border-left: 1px solid var(--line); padding-right: 0; }
.ig:nth-last-child(-n+2) { border-bottom: none; }
.ig__n {
  display: block; font-size: .65rem; font-weight: 700; letter-spacing: .14em;
  color: var(--white-3); margin-bottom: 1rem;
}
.ig h3 { font-size: .95rem; font-weight: 700; color: var(--white); margin-bottom: .4rem; letter-spacing: -.01em; }
.ig p { font-size: .83rem; color: var(--white-2); line-height: 1.65; }

/* CTA */
.cta { padding: 10rem 0; text-align: center; }
.cta__e {
  font-size: .7rem; font-weight: 600; letter-spacing: .18em; text-transform: uppercase;
  color: var(--white-3); margin-bottom: 1.5rem;
}
.cta__h {
  font-size: clamp(5rem, 14vw, 12rem); font-weight: 800;
  letter-spacing: -.05em; line-height: .88;
  color: var(--white); margin-bottom: 3.5rem;
}
.cta__h em { font-style: italic; color: var(--white-2); }
.cta__btn {
  display: inline-flex; align-items: center; gap: .75rem;
  font-size: .78rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
  color: var(--bg); background: var(--white);
  text-decoration: none; padding: 1.1rem 2.5rem;
  transition: opacity .2s;
}
.cta__btn:hover { opacity: .75; }

.arr { transition: transform .25s; }
a:hover .arr { transform: translateX(5px); }

/* RESPONSIVE */
@media (max-width: 1024px) {
  .pr { grid-template-columns: 10rem 1fr; grid-template-rows: auto auto; }
  .pr__r { grid-column: 2; text-align: left; display: flex; align-items: center; gap: 2rem; }
  .pr__price { margin-bottom: 0; }
  .inc { grid-template-columns: 1fr; gap: 4rem; }
  .inc__h { position: static; }
}
@media (max-width: 768px) {
  .inc__g { grid-template-columns: 1fr; }
  .ig:nth-child(even) { padding-left: 0; border-left: none; }
  .ig:nth-last-child(-n+2) { border-bottom: 1px solid var(--line); }
  .ig:last-child { border-bottom: none; }
}
@media (max-width: 640px) {
  .pg { padding: 0 1.5rem; }
  .hero { padding: 5rem 0 4rem; }
  .hero__h { font-size: clamp(3.5rem, 16vw, 6rem); }
  .pr { grid-template-columns: 1fr; }
  .pr__l { flex-direction: column; gap: .5rem; }
  .pr__n { display: none; }
  .pr__r { grid-column: 1; text-align: left; }
  .ticker { margin: 0 -1.5rem; }
  .cta { padding: 6rem 0; }
}
</style>
