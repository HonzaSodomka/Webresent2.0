---
// src/pages/objednavka.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Nezávazná poptávka | Webresent">
  <main class="max-w-6xl 2xl:max-w-7xl mx-auto px-6 overflow-hidden py-12 lg:py-20 relative">
    
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">
      
      <div class="lg:col-span-5 flex flex-col lg:sticky lg:top-32 fade-in-up">
        
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-50 border border-blue-100 text-sm 2xl:text-base font-semibold text-blue-700 mb-6 2xl:mb-8 self-start">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-blue-600"></span>
          </span>
          Přijímám nové projekty
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-5xl 2xl:text-6xl font-extrabold tracking-tighter text-zinc-900 leading-[1.05] mb-6">
          Pojďme probrat váš <span class="text-blue-600">projekt.</span>
        </h1>

        <p class="text-lg text-zinc-600 leading-relaxed font-medium mb-10 max-w-md">
          Vyplňte krátký formulář a já se vám <strong>do 24 hodin</strong> ozvu. Nejdřív si vše nezávazně promluvíme, pak teprve řešíme peníze a postup.
        </p>

        <div class="space-y-6 mb-12 relative">
          <div class="absolute left-[19px] top-6 bottom-6 w-px bg-zinc-200 hidden sm:block z-0"></div>
          
          <div class="flex gap-5 relative z-10">
            <div class="w-10 h-10 rounded-full bg-blue-600 text-white flex items-center justify-center font-bold flex-shrink-0 shadow-md shadow-blue-500/30">1</div>
            <div class="pt-2">
              <h3 class="font-bold text-zinc-900 mb-1">Pošlete poptávku</h3>
              <p class="text-sm text-zinc-500 font-medium">Vyberte si typ webu z mé nabídky a popište mi svou představu.</p>
            </div>
          </div>
          <div class="flex gap-5 relative z-10">
            <div class="w-10 h-10 rounded-full bg-white border-2 border-zinc-200 text-zinc-400 flex items-center justify-center font-bold flex-shrink-0">2</div>
            <div class="pt-2">
              <h3 class="font-bold text-zinc-900 mb-1">Návrh řešení a cena</h3>
              <p class="text-sm text-zinc-500 font-medium">Zdarma navrhnu postup, vyberu technologie a pošlu přesnou kalkulaci.</p>
            </div>
          </div>
          <div class="flex gap-5 relative z-10">
            <div class="w-10 h-10 rounded-full bg-white border-2 border-zinc-200 text-zinc-400 flex items-center justify-center font-bold flex-shrink-0">3</div>
            <div class="pt-2">
              <h3 class="font-bold text-zinc-900 mb-1">Pustíme se do toho</h3>
              <p class="text-sm text-zinc-500 font-medium">Pokud si plácneme, začnu hned tvořit váš nový web.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="lg:col-span-7 fade-in-up" style="animation-delay: 0.15s;">
        <div id="form-container" class="bg-white rounded-[2rem] sm:rounded-[2.5rem] p-6 sm:p-10 lg:p-12 border border-zinc-200 shadow-xl relative overflow-hidden transition-all duration-500 min-h-[600px] flex flex-col">
          
          <div class="absolute top-0 right-0 w-64 h-64 bg-blue-50 rounded-full blur-3xl -z-10 opacity-70 translate-x-1/2 -translate-y-1/2"></div>

          <form id="contact-form" class="flex flex-col gap-6 sm:gap-8 relative z-10 flex-grow">
            
            <div class="grid sm:grid-cols-2 gap-6">
              <div class="flex flex-col gap-2">
                <label for="name" class="text-sm font-bold text-zinc-900">Jméno a příjmení <span class="text-blue-600">*</span></label>
                <input type="text" id="name" name="name" required placeholder="Jan Novák" class="w-full px-4 py-3.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-all shadow-sm">
              </div>
              <div class="flex flex-col gap-2">
                <label for="phone" class="text-sm font-bold text-zinc-900">Telefon <span class="text-zinc-400 font-medium">(volitelné)</span></label>
                <input type="tel" id="phone" name="phone" placeholder="+420 123 456 789" class="w-full px-4 py-3.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-all shadow-sm">
              </div>
            </div>
            <div class="flex flex-col gap-2">
              <label for="email" class="text-sm font-bold text-zinc-900">E-mail <span class="text-blue-600">*</span></label>
              <input type="email" id="email" name="email" required placeholder="jan@novak.cz" class="w-full px-4 py-3.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-all shadow-sm">
            </div>

            <hr class="border-zinc-100">

            <div class="flex flex-col gap-3">
              <label class="text-sm font-bold text-zinc-900 mb-1">Jaký typ webu hledáte?</label>
              <div class="grid sm:grid-cols-2 gap-3">
                
                <label class="relative cursor-pointer group">
                  <input type="radio" name="project_type" value="Statický web" class="peer sr-only" checked>
                  <div class="h-full w-full p-4 bg-zinc-50 border-2 border-zinc-200 rounded-xl transition-all hover:border-zinc-300 peer-checked:bg-blue-50/50 peer-checked:border-blue-500 peer-checked:shadow-sm peer-checked:[&_.radio-title]:text-blue-700 peer-checked:[&_.radio-border]:border-blue-600 peer-checked:[&_.radio-dot]:opacity-100 peer-checked:[&_.radio-price]:text-blue-600 peer-checked:[&_.radio-desc]:text-blue-700/80">
                    <div class="flex items-center justify-between mb-1">
                      <span class="radio-title font-bold text-zinc-900 transition-colors">Statický web</span>
                      <div class="radio-border w-4 h-4 rounded-full border-2 border-zinc-300 flex items-center justify-center transition-colors">
                        <div class="radio-dot w-2 h-2 bg-blue-600 rounded-full opacity-0 transition-opacity"></div>
                      </div>
                    </div>
                    <p class="radio-price text-[10px] font-bold text-zinc-500 uppercase tracking-wide mb-1 transition-colors">od 9 900 Kč</p>
                    <p class="radio-desc text-xs text-zinc-500 font-medium transition-colors">Rychlá vizitka s kontaktem.</p>
                  </div>
                </label>

                <label class="relative cursor-pointer group">
                  <input type="radio" name="project_type" value="Upravitelný web" class="peer sr-only">
                  <div class="h-full w-full p-4 bg-zinc-50 border-2 border-zinc-200 rounded-xl transition-all hover:border-zinc-300 peer-checked:bg-blue-50/50 peer-checked:border-blue-500 peer-checked:shadow-sm peer-checked:[&_.radio-title]:text-blue-700 peer-checked:[&_.radio-border]:border-blue-600 peer-checked:[&_.radio-dot]:opacity-100 peer-checked:[&_.radio-price]:text-blue-600 peer-checked:[&_.radio-desc]:text-blue-700/80">
                    <div class="flex items-center justify-between mb-1">
                      <span class="radio-title font-bold text-zinc-900 transition-colors">Upravitelný web</span>
                      <div class="radio-border w-4 h-4 rounded-full border-2 border-zinc-300 flex items-center justify-center transition-colors">
                        <div class="radio-dot w-2 h-2 bg-blue-600 rounded-full opacity-0 transition-opacity"></div>
                      </div>
                    </div>
                    <p class="radio-price text-[10px] font-bold text-zinc-500 uppercase tracking-wide mb-1 transition-colors">od 19 900 Kč</p>
                    <p class="radio-desc text-xs text-zinc-500 font-medium transition-colors">Sami si měníte texty a fotky.</p>
                  </div>
                </label>

                <label class="relative cursor-pointer group">
                  <input type="radio" name="project_type" value="Aplikace / E-shop" class="peer sr-only">
                  <div class="h-full w-full p-4 bg-zinc-50 border-2 border-zinc-200 rounded-xl transition-all hover:border-zinc-300 peer-checked:bg-blue-50/50 peer-checked:border-blue-500 peer-checked:shadow-sm peer-checked:[&_.radio-title]:text-blue-700 peer-checked:[&_.radio-border]:border-blue-600 peer-checked:[&_.radio-dot]:opacity-100 peer-checked:[&_.radio-price]:text-blue-600 peer-checked:[&_.radio-desc]:text-blue-700/80">
                    <div class="flex items-center justify-between mb-1">
                      <span class="radio-title font-bold text-zinc-900 transition-colors">Aplikace / E-shop</span>
                      <div class="radio-border w-4 h-4 rounded-full border-2 border-zinc-300 flex items-center justify-center transition-colors">
                        <div class="radio-dot w-2 h-2 bg-blue-600 rounded-full opacity-0 transition-opacity"></div>
                      </div>
                    </div>
                    <p class="radio-price text-[10px] font-bold text-zinc-500 uppercase tracking-wide mb-1 transition-colors">Individuálně</p>
                    <p class="radio-desc text-xs text-zinc-500 font-medium transition-colors">Složitější systém na míru.</p>
                  </div>
                </label>

                <label class="relative cursor-pointer group">
                  <input type="radio" name="project_type" value="Redesign stávajícího webu" class="peer sr-only">
                  <div class="h-full w-full p-4 bg-zinc-50 border-2 border-zinc-200 rounded-xl transition-all hover:border-zinc-300 peer-checked:bg-blue-50/50 peer-checked:border-blue-500 peer-checked:shadow-sm peer-checked:[&_.radio-title]:text-blue-700 peer-checked:[&_.radio-border]:border-blue-600 peer-checked:[&_.radio-dot]:opacity-100 peer-checked:[&_.radio-price]:text-blue-600 peer-checked:[&_.radio-desc]:text-blue-700/80">
                    <div class="flex items-center justify-between mb-1">
                      <span class="radio-title font-bold text-zinc-900 transition-colors">Mám stávající web</span>
                      <div class="radio-border w-4 h-4 rounded-full border-2 border-zinc-300 flex items-center justify-center transition-colors">
                        <div class="radio-dot w-2 h-2 bg-blue-600 rounded-full opacity-0 transition-opacity"></div>
                      </div>
                    </div>
                    <p class="radio-price text-[10px] font-bold text-zinc-500 uppercase tracking-wide mb-1 transition-colors">Redesign</p>
                    <p class="radio-desc text-xs text-zinc-500 font-medium transition-colors">Chci ho vylepšit nebo předělat.</p>
                  </div>
                </label>

                <label class="relative cursor-pointer group sm:col-span-2">
                  <input type="radio" name="project_type" value="Jen konzultace" class="peer sr-only">
                  <div class="h-full w-full p-4 bg-zinc-50 border-2 border-zinc-200 rounded-xl transition-all hover:border-zinc-300 peer-checked:bg-blue-50/50 peer-checked:border-blue-500 peer-checked:shadow-sm peer-checked:[&_.radio-title]:text-blue-700 peer-checked:[&_.radio-border]:border-blue-600 peer-checked:[&_.radio-dot]:opacity-100 peer-checked:[&_.radio-desc]:text-blue-700/80">
                    <div class="flex items-center justify-between mb-1">
                      <span class="radio-title font-bold text-zinc-900 transition-colors">Nejsem si jistý / Chci poradit</span>
                      <div class="radio-border w-4 h-4 rounded-full border-2 border-zinc-300 flex items-center justify-center transition-colors">
                        <div class="radio-dot w-2 h-2 bg-blue-600 rounded-full opacity-0 transition-opacity"></div>
                      </div>
                    </div>
                    <p class="radio-desc text-xs text-zinc-500 font-medium transition-colors">Nevadí, probereme vaši situaci a navrhnu řešení, které dává smysl.</p>
                  </div>
                </label>

              </div>
            </div>

            <div id="existing-url-wrapper" class="hidden flex-col gap-2 overflow-hidden transition-all duration-300 opacity-0 -translate-y-2">
              <label for="existing_url" class="text-sm font-bold text-zinc-900">Odkaz na váš současný web <span class="text-blue-600">*</span></label>
              <input type="url" id="existing_url" name="existing_url" placeholder="https://www.mujweb.cz" class="w-full px-4 py-3.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-all shadow-sm">
            </div>

            <hr class="border-zinc-100">

            <div class="flex flex-col gap-2 relative">
              <div class="flex justify-between items-end">
                <label for="message" class="text-sm font-bold text-zinc-900">Popište mi svůj projekt <span class="text-blue-600">*</span></label>
                <span id="char-count" class="text-xs font-medium text-zinc-400">0 / 1000</span>
              </div>
              <textarea id="message" name="message" required rows="4" maxlength="1000" placeholder="Čím víc mi prozradíte (koho cílíme, co se vám líbí, jaký je účel webu), tím lépe se na naši komunikaci připravím..." class="w-full px-4 py-3.5 bg-zinc-50 border border-zinc-200 rounded-xl text-zinc-900 placeholder-zinc-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:bg-white transition-all resize-y custom-scrollbar shadow-sm"></textarea>
            </div>

            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 pt-2 mt-auto border-t border-zinc-100/50">
              <p class="text-xs text-zinc-500 font-medium max-w-[250px] leading-relaxed pt-2">
                Odesláním souhlasíte se zpracováním osobních údajů pro účely vyřízení vaší poptávky.
              </p>
              <button type="submit" id="submit-btn" class="relative inline-flex items-center justify-center gap-2 px-8 py-4 text-base rounded-full bg-blue-600 text-white font-bold hover:bg-blue-500 focus:outline-none focus:ring-4 focus:ring-blue-500/30 transition-all duration-300 shadow-lg hover:shadow-[0_10px_20px_-10px_rgba(37,99,235,0.6)] hover:-translate-y-0.5 w-full sm:w-auto overflow-hidden group">
                <span id="btn-text" class="flex items-center gap-2 transition-transform duration-300">
                  Odeslat poptávku
                  <svg class="w-5 h-5 transform group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                </span>
                
                <span id="btn-spinner" class="absolute inset-0 flex items-center justify-center bg-blue-600 opacity-0 translate-y-full transition-all duration-300">
                  <svg class="animate-spin w-6 h-6 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                </span>
              </button>
            </div>
          </form>

          <div id="success-state" class="absolute inset-0 bg-white z-20 flex flex-col items-center justify-center text-center p-8 opacity-0 pointer-events-none transition-all duration-500 rounded-[2rem] sm:rounded-[2.5rem]">
            <div class="w-20 h-20 bg-green-50 border border-green-100 rounded-full flex items-center justify-center mb-6 shadow-sm">
              <div class="w-14 h-14 bg-green-500 rounded-full flex items-center justify-center text-white shadow-md animate-bounce" style="animation-iteration-count: 2;">
                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
            </div>
            <h2 class="text-3xl font-extrabold text-zinc-900 mb-4 tracking-tight">Poptávka dorazila!</h2>
            <p class="text-zinc-600 font-medium max-w-sm mb-8 text-lg">
              Díky za váš čas. Vše mám u sebe a <strong>do 24 hodin</strong> se vám ozvu na zadaný e-mail nebo telefon.
            </p>
            <a href="/" class="px-8 py-3.5 rounded-full bg-zinc-100 text-zinc-900 font-bold hover:bg-zinc-200 transition-colors shadow-sm">
              Zpět na hlavní stranu
            </a>
          </div>

        </div>
      </div>
    </div>
  </main>
</Layout>

<style>
  .custom-scrollbar::-webkit-scrollbar { width: 6px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background-color: #e4e4e7; border-radius: 20px; }
  .custom-scrollbar:focus::-webkit-scrollbar-thumb { background-color: #cbd5e1; }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const messageInput = document.getElementById('message') as HTMLTextAreaElement;
    const charCount = document.getElementById('char-count');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const btnText = document.getElementById('btn-text');
    const btnSpinner = document.getElementById('btn-spinner');
    const successState = document.getElementById('success-state');
    
    // Logika pro zobrazení URL stávajícího webu
    const radioButtons = document.querySelectorAll('input[name="project_type"]');
    const urlWrapper = document.getElementById('existing-url-wrapper');
    const urlInput = document.getElementById('existing_url') as HTMLInputElement;

    if (!form) return;

    // Přepínání pole URL s plynulou animací
    radioButtons.forEach(radio => {
      radio.addEventListener('change', (e) => {
        const target = e.target as HTMLInputElement;
        if (target.value === 'Redesign stávajícího webu') {
          urlWrapper?.classList.remove('hidden');
          urlWrapper?.classList.add('flex');
          setTimeout(() => {
            urlWrapper?.classList.remove('opacity-0', '-translate-y-2');
            urlWrapper?.classList.add('opacity-100', 'translate-y-0');
          }, 10);
          urlInput?.setAttribute('required', 'true');
        } else {
          urlWrapper?.classList.remove('opacity-100', 'translate-y-0');
          urlWrapper?.classList.add('opacity-0', '-translate-y-2');
          setTimeout(() => {
            urlWrapper?.classList.add('hidden');
            urlWrapper?.classList.remove('flex');
          }, 300);
          urlInput?.removeAttribute('required');
          if (urlInput) urlInput.value = ''; // Vyčištění pole
        }
      });
    });

    // Interaktivní počítadlo znaků
    messageInput?.addEventListener('input', () => {
      if (charCount) {
        const length = messageInput.value.length;
        charCount.textContent = `${length} / 1000`;
        if (length > 900) charCount.classList.add('text-orange-500');
        else charCount.classList.remove('text-orange-500');
      }
    });

    // Simulace AJAX odesílání formuláře
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // UX Animace tlačítka: Tlačítko přejde do stavu "Načítání" a zamkne se
      if (btnText && btnSpinner && submitBtn) {
        btnText.classList.add('opacity-0', '-translate-y-full');
        btnSpinner.classList.remove('opacity-0', 'translate-y-full');
        btnSpinner.classList.add('opacity-100', 'translate-y-0');
        submitBtn.setAttribute('disabled', 'true');
        submitBtn.classList.add('cursor-not-allowed', 'opacity-90');
      }

      try {
        // SIMULACE ODESLÁNÍ SERVERU (čeká 1.5 sekundy)
        await new Promise(resolve => setTimeout(resolve, 1500)); 

        // Zobrazení úspěšné hlášky "Poptávka dorazila" s prolnutím a zablokování formuláře
        if (successState) {
          successState.classList.remove('opacity-0', 'pointer-events-none');
          successState.classList.add('opacity-100', 'pointer-events-auto');
        }

      } catch (error) {
        alert('Omlouvám se, něco se pokazilo. Zkuste to prosím znovu nebo mi napište na e-mail.');
        // Vrácení tlačítka zpět v případě chyby
        if (btnText && btnSpinner && submitBtn) {
          btnText.classList.remove('opacity-0', '-translate-y-full');
          btnSpinner.classList.remove('opacity-100', 'translate-y-0');
          btnSpinner.classList.add('opacity-0', 'translate-y-full');
          submitBtn.removeAttribute('disabled');
          submitBtn.classList.remove('cursor-not-allowed', 'opacity-90');
        }
      }
    });
  });
</script>