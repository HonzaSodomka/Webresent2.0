---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/Header.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="cs" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Webresent - Web, který vás reprezentuje." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		
		<title>{title} | Webresent</title>
		<ViewTransitions />
	</head>
	<body class="bg-zinc-50 text-zinc-900 font-['Plus_Jakarta_Sans',_sans-serif] antialiased selection:bg-zinc-900 selection:text-zinc-50 pt-20">
		<Header />
		<slot />
	</body>
</html>