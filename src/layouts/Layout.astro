---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
}

const {
  title,
  description = 'Webresent — weby které vydělávají. Na míru, bez kompromisů.',
  noindex = false,
  ogImage = '/images/og-image.jpg',
} = Astro.props;

const siteURL = 'https://webresent.cz';
const canonicalURL = new URL(Astro.url.pathname, siteURL).href;
const ogImageURL = new URL(ogImage, siteURL).href;
---
<!doctype html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noindex && <meta name="robots" content="noindex, follow" />}
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
  <meta name="theme-color" content="#0e0e0e" />
  <title>{title}</title>
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:locale" content="cs_CZ" />
  <meta property="og:site_name" content="Webresent" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />
  <script is:inline type="application/ld+json">{
    "@context": "https://schema.org",
    "@graph": [
      { "@type": "WebSite", "@id": "https://webresent.cz/#website", "url": "https://webresent.cz", "name": "Webresent" },
      { "@type": ["LocalBusiness","ProfessionalService"], "@id": "https://webresent.cz/#business",
        "name": "Webresent", "url": "https://webresent.cz",
        "telephone": "+420604994883", "email": "info@webresent.cz",
        "founder": { "@type": "Person", "name": "Jan Sodomka", "honorificPrefix": "Bc." },
        "areaServed": { "@type": "Country", "name": "\u010cesk\u00e1 republika" },
        "address": { "@type": "PostalAddress", "addressLocality": "Mlad\u00e1 Boleslav", "addressCountry": "CZ" },
        "priceRange": "9 900 K\u010d \u2013 50 000 K\u010d" }
    ]
  }</script>
  <ClientRouter />
</head>
<body style="padding-top:64px; display:flex; flex-direction:column; min-height:100vh;">
  <script>document.documentElement.classList.add('js')</script>

  <div class="cursor" id="cur"></div>
  <a href="#main-content" style="position:absolute;left:-9999px">P\u0159esko\u010dit na obsah</a>

  <Header />
  <div style="flex:1" id="main-content"><slot /></div>
  <Footer />

  <script>
    import Lenis from 'lenis';

    let _heroResize: (() => void) | null = null;
    let _heroOrient: (() => void) | null = null;

    document.addEventListener('astro:page-load', () => {
      // Lenis
      if ((window as any).lenis) (window as any).lenis.destroy();
      (window as any).lenis = new Lenis({ lerp: 0.1, wheelMultiplier: 1.0, smoothWheel: true });
      const raf = (t: number) => { (window as any).lenis.raf(t); requestAnimationFrame(raf); };
      requestAnimationFrame(raf);

      // Reveal
      const io = new IntersectionObserver((entries, obs) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            (e.target as HTMLElement).style.transitionDelay = (e.target as HTMLElement).dataset.delay || '0s';
            e.target.classList.add('is-visible');
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.06 });
      document.querySelectorAll('.reveal').forEach(el => io.observe(el));

      // Scroll-reveal legacy
      const io2 = new IntersectionObserver((entries, obs) => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('active'); obs.unobserve(e.target); } });
      }, { threshold: 0.1 });
      document.querySelectorAll('.scroll-reveal').forEach(el => io2.observe(el));

      // Custom cursor
      const cur = document.getElementById('cur');
      if (cur && window.matchMedia('(pointer: fine)').matches) {
        document.addEventListener('mousemove', e => {
          cur.style.left = e.clientX + 'px';
          cur.style.top  = e.clientY + 'px';
        });
        document.querySelectorAll('a, button').forEach(el => {
          el.addEventListener('mouseenter', () => cur.classList.add('cursor--big'));
          el.addEventListener('mouseleave', () => cur.classList.remove('cursor--big'));
        });
      } else if (cur) {
        cur.style.display = 'none';
      }

      // Hero dynamic height
      if (_heroResize) { window.removeEventListener('resize', _heroResize); _heroResize = null; }
      if (_heroOrient) { window.removeEventListener('orientationchange', _heroOrient); _heroOrient = null; }

      const hero = document.getElementById('hero');
      if (hero) {
        let lastW = window.innerWidth;
        const setH = () => {
          const hdr = document.querySelector('header');
          const offset = hdr ? hdr.getBoundingClientRect().bottom : 64;
          hero.style.minHeight = (window.innerHeight - offset) + 'px';
        };
        setH();
        _heroResize = () => { if (window.innerWidth !== lastW) { lastW = window.innerWidth; setH(); } };
        _heroOrient = () => setTimeout(setH, 100);
        window.addEventListener('resize', _heroResize);
        window.addEventListener('orientationchange', _heroOrient);
      }
    });
  </script>
</body>
</html>
