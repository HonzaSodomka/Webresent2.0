---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="cs" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Webresent - Web, který vás reprezentuje." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		
		<!-- Lenis Smooth Scroll -->
		<script src="https://unpkg.com/lenis@1.1.20/dist/lenis.min.js"></script>

		<title>{title} | Webresent</title>
		<ViewTransitions />
	</head>
	<body class="bg-zinc-50 text-zinc-900 font-['Plus_Jakarta_Sans',_sans-serif] antialiased selection:bg-zinc-900 selection:text-zinc-50 pt-20 flex flex-col min-h-screen relative">
		
		<!-- Premium Noise Texture Overlay -->
		<div class="pointer-events-none fixed inset-0 z-[100] opacity-[0.035] mix-blend-overlay" style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E&quot;);"></div>

		<Header />
		<div class="flex-grow">
			<slot />
		</div>
		<Footer />

		<script>
			// Oprava TypeScript chyby pro objekt window (declare global window)
			declare global {
				interface Window {
					lenis: any;
					Lenis: any;
				}
			}

			// Inicializace Lenis smooth scrollingu a globálních skriptů
			document.addEventListener('astro:page-load', () => {
				
				// Inicializace Lenis
				if (window.lenis) {
					window.lenis.destroy();
				}

				window.lenis = new window.Lenis({
					lerp: 0.15,
					wheelMultiplier: 1.2,
					smoothWheel: true,
				});

				function raf(time: number) {
					window.lenis.raf(time);
					requestAnimationFrame(raf);
				}

				requestAnimationFrame(raf);

				// Globální Scroll Reveal Intersection Observer
				const observer = new IntersectionObserver((entries, obs) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							entry.target.classList.add('active');
							obs.unobserve(entry.target);
						}
					});
				}, { threshold: 0.1 });

				document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));

				// ─────────────────────────────────────────────────────────────
				// SDÍLENÝ HERO HEIGHT SCRIPT
				// Nastavuje minHeight hero sekce podle skutečné výšky headeru,
				// místo pevných 80px. Funguje na index, portfolio i o-mne.
				// ─────────────────────────────────────────────────────────────
				const hero = document.getElementById('hero');
				if (hero) {
					let lastWidth = window.innerWidth;

					const setHeroHeight = () => {
						// Použijeme skutečnou výšku headeru místo pevné konstanty 80px.
						// Fallback na 80 pro případ, že by header nebyl v DOMu.
						const headerEl = document.querySelector('header');
						const headerHeight = headerEl ? headerEl.offsetHeight : 80;
						hero.style.minHeight = `${window.innerHeight - headerHeight}px`;
					};

					setHeroHeight();

					window.addEventListener('resize', () => {
						// Přepočítáme jen při změně šířky (ne při scroll-hide adresního řádku na iOS)
						if (window.innerWidth !== lastWidth) {
							lastWidth = window.innerWidth;
							setHeroHeight();
						}
					});

					window.addEventListener('orientationchange', () => {
						setTimeout(setHeroHeight, 100);
					});
				}
			});
		</script>
	</body>
</html>