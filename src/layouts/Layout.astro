---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
}

const {
  title,
  description = 'Webresent — prémiové weby na míru pro české firmy a živnostníky. Čistý kód, bleskové načítání a technické SEO.',
  noindex = false,
  ogImage = '/images/og-image.jpg',
} = Astro.props;

const siteURL = 'https://webresent.cz';
const canonicalURL = new URL(Astro.url.pathname, siteURL).href;
const ogImageURL = new URL(ogImage, siteURL).href;
---

<!doctype html>
<html lang="cs" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <!-- ── Canonical ─────────────────────────────────────────────────────── -->
    <link rel="canonical" href={canonicalURL} />

    <!-- ── Noindex (jen pro stránky bez SEO hodnoty) ─────────────────────── -->
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- ── Favicon ───────────────────────────────────────────────────────── -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- ── Title ─────────────────────────────────────────────────────────── -->
    <title>{title}</title>

    <!-- ── Open Graph ────────────────────────────────────────────────────── -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="cs_CZ" />
    <meta property="og:site_name" content="Webresent" />

    <!-- ── Twitter Card ──────────────────────────────────────────────────── -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- ── Preconnect pro externí zdroje ─────────────────────────────────── -->
    <link rel="preconnect" href="https://cdn.simpleicons.org" />
    <link rel="dns-prefetch" href="https://cdn.simpleicons.org" />

    <!-- ── Structured Data: WebSite + LocalBusiness ──────────────────────── -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebSite",
            "@id": "https://webresent.cz/#website",
            "url": "https://webresent.cz",
            "name": "Webresent",
            "description": "Prémiové weby na míru pro české firmy a živnostníky."
          },
          {
            "@type": ["LocalBusiness", "ProfessionalService"],
            "@id": "https://webresent.cz/#business",
            "name": "Webresent",
            "url": "https://webresent.cz",
            "telephone": "+420604994883",
            "email": "h.sodomka@seznam.cz",
            "description": "Prémiové weby na míru pro české firmy a živnostníky. Čistý kód, bleskové načítání a technické SEO.",
            "founder": {
              "@type": "Person",
              "name": "Jan Sodomka",
              "honorificPrefix": "Bc."
            },
            "areaServed": {
              "@type": "Country",
              "name": "Česká republika"
            },
            "address": {
              "@type": "PostalAddress",
              "addressLocality": "Mladá Boleslav",
              "addressCountry": "CZ"
            },
            "priceRange": "9 900 Kč – 50 000 Kč",
            "knowsLanguage": ["cs", "en"],
            "sameAs": []
          }
        ]
      }
    </script>

    <ViewTransitions />
  </head>
  <body class="bg-zinc-50 text-zinc-900 font-['Plus_Jakarta_Sans',_sans-serif] antialiased selection:bg-zinc-900 selection:text-zinc-50 pt-20 flex flex-col min-h-screen relative">

    <!-- FOUC FIX: Přidá třídu .js na <html> okamžitě před prvním renderem. -->
    <script>document.documentElement.classList.add('js')</script>

    <!-- PŘÍSTUPNOST: Skip to content link -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-1/2 focus:-translate-x-1/2 focus:z-[200] focus:px-6 focus:py-3 focus:bg-white focus:text-zinc-900 focus:font-bold focus:rounded-full focus:border focus:border-zinc-300 focus:shadow-xl focus:outline-none focus:ring-2 focus:ring-blue-500"
    >
      Přeskočit na hlavní obsah
    </a>

    <!-- Premium Noise Texture Overlay -->
    <div
      aria-hidden="true"
      class="pointer-events-none fixed inset-0 z-[100] opacity-[0.035] mix-blend-overlay"
      style="background-image: url(&quot;data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E&quot;);">
    </div>

    <Header />

    <div class="flex-grow" id="main-content">
      <slot />
    </div>

    <Footer />

    <script>
      import Lenis from 'lenis';

      declare global {
        interface Window {
          lenis: Lenis;
        }
      }

      let heroResizeHandler: (() => void) | null = null;
      let heroOrientationHandler: (() => void) | null = null;

      document.addEventListener('astro:page-load', () => {

        if (window.lenis) {
          window.lenis.destroy();
        }

        window.lenis = new Lenis({
          lerp: 0.15,
          wheelMultiplier: 1.2,
          smoothWheel: true,
        });

        function raf(time: number) {
          window.lenis.raf(time);
          requestAnimationFrame(raf);
        }

        requestAnimationFrame(raf);

        const observer = new IntersectionObserver((entries, obs) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('active');
              obs.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1 });

        document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));

        const hero = document.getElementById('hero');

        if (heroResizeHandler) {
          window.removeEventListener('resize', heroResizeHandler);
          heroResizeHandler = null;
        }
        if (heroOrientationHandler) {
          window.removeEventListener('orientationchange', heroOrientationHandler);
          heroOrientationHandler = null;
        }

        if (hero) {
          let lastWidth = window.innerWidth;

          const setHeroHeight = () => {
            const headerEl = document.querySelector('header');
            if (headerEl) {
              const rect = headerEl.getBoundingClientRect();
              const headerBottom = rect.top + rect.height;
              hero.style.minHeight = `${window.innerHeight - headerBottom}px`;
            } else {
              hero.style.minHeight = `${window.innerHeight - 80}px`;
            }
          };

          setHeroHeight();

          heroResizeHandler = () => {
            if (window.innerWidth !== lastWidth) {
              lastWidth = window.innerWidth;
              setHeroHeight();
            }
          };

          heroOrientationHandler = () => {
            setTimeout(setHeroHeight, 100);
          };

          window.addEventListener('resize', heroResizeHandler);
          window.addEventListener('orientationchange', heroOrientationHandler);
        }
      });
    </script>
  </body>
</html>