---
const navItems = [
  { label: 'Domů', href: '/' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Ceník', href: '/cenik' },
  { label: 'O mně', href: '/o-mne' },
];
const currentPath = Astro.url.pathname;
const isObjednavka = currentPath === '/objednavka';
---

<header class="site-header">
  <div class="site-header__inner">

    <a href="/" class="site-header__logo" aria-label="Webresent — domů">
      Webresent
    </a>

    <nav class="site-header__nav" aria-label="Hlavní navigace">
      {navItems.map(item => (
        <a
          href={item.href}
          class={`site-header__nav-link${currentPath === item.href ? ' site-header__nav-link--active' : ''}`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href="/objednavka"
      class={`site-header__cta${isObjednavka ? ' site-header__cta--active' : ''}`}
    >
      Poptat web
    </a>

    <button
      id="menu-toggle"
      aria-label="Otevřít menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="site-header__hamburger"
    >
      <span></span>
      <span></span>
    </button>
  </div>

  <div id="mobile-menu" role="navigation" aria-label="Mobilní menu" class="mobile-menu" hidden>
    <nav class="mobile-menu__nav">
      {navItems.map(item => (
        <a href={item.href} class="mobile-menu__link">{item.label}</a>
      ))}
      <a href="/objednavka" class="mobile-menu__cta">Poptat web →</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background: rgba(245, 240, 232, 0.93);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--cream-border);
  }
  .site-header__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .site-header__logo {
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 0.2s ease;
  }
  .site-header__logo:hover { opacity: 0.5; }

  .site-header__nav {
    display: flex;
    align-items: center;
  }
  .site-header__nav-link {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mid);
    text-decoration: none;
    padding: 0.4rem 0.9rem;
    transition: color 0.2s ease;
  }
  .site-header__nav-link:hover,
  .site-header__nav-link--active { color: var(--ink); }

  .site-header__cta {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cream);
    background: var(--ink);
    text-decoration: none;
    padding: 0.6rem 1.4rem;
    border: 1.5px solid var(--ink);
    flex-shrink: 0;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .site-header__cta:hover {
    background: transparent;
    color: var(--ink);
  }
  .site-header__cta--active {
    background: transparent;
    color: var(--ink);
  }

  .site-header__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .site-header__hamburger span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--ink);
    transition: transform 0.25s ease;
  }
  .site-header__hamburger.is-open span:first-child { transform: translateY(3.25px) rotate(45deg); }
  .site-header__hamburger.is-open span:last-child  { transform: translateY(-3.25px) rotate(-45deg); }

  .mobile-menu {
    border-top: 1px solid var(--cream-border);
    background: var(--cream);
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .mobile-menu:not([hidden]) { max-height: 420px; }
  .mobile-menu__nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 2rem;
    display: flex;
    flex-direction: column;
  }
  .mobile-menu__link {
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-mid);
    text-decoration: none;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--cream-border);
    transition: color 0.2s ease;
  }
  .mobile-menu__link:hover { color: var(--ink); }
  .mobile-menu__cta {
    margin-top: 1.25rem;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    align-self: flex-start;
    transition: opacity 0.2s ease;
  }
  .mobile-menu__cta:hover { opacity: 0.5; }

  @media (max-width: 768px) {
    .site-header__nav, .site-header__cta { display: none; }
    .site-header__hamburger { display: flex; }
  }
  @media (max-width: 600px) {
    .site-header__inner { padding: 0 1.25rem; }
    .mobile-menu__nav { padding: 1.25rem 1.25rem; }
  }
</style>

<script>
  function initHeader() {
    const toggle = document.getElementById('menu-toggle') as HTMLButtonElement | null;
    const menu = document.getElementById('mobile-menu') as HTMLElement | null;
    if (!toggle || !menu) return;
    let open = false;
    const openMenu = () => {
      open = true;
      menu.removeAttribute('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Zavřít menu');
      toggle.classList.add('is-open');
    };
    const closeMenu = () => {
      open = false;
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Otevřít menu');
      toggle.classList.remove('is-open');
      setTimeout(() => menu.setAttribute('hidden', ''), 350);
    };
    toggle.addEventListener('click', () => open ? closeMenu() : openMenu());
    menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => { if (open) closeMenu(); }));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && open) closeMenu(); });
  }
  document.addEventListener('astro:page-load', initHeader);
</script>
