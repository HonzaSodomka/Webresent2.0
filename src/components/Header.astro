---
// src/components/Header.astro
const navItems = [
  { label: 'Domů', href: '/' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Ceník', href: '/cenik' },
  { label: 'O mně', href: '/o-mne' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-4 left-0 w-full z-50 px-4 pointer-events-none">
  <div class="max-w-4xl mx-auto flex items-center justify-between bg-white/80 backdrop-blur-md border border-zinc-200/50 shadow-[0_8px_30px_-10px_rgba(0,0,0,0.1)] rounded-full h-16 px-6 pointer-events-auto transition-all duration-300">
    
    <!-- Logo -->
    <a href="/" class="text-xl font-extrabold text-zinc-900 group">
      Webresent<span class="text-blue-600 transition-colors group-hover:text-blue-500">.</span>
    </a>

    <!-- Desktop Navigace -->
    <nav class="hidden md:flex items-center gap-1">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class={`px-4 py-2 rounded-full text-sm font-bold transition-all ${
            currentPath === item.href
              ? 'text-zinc-900 bg-zinc-100'
              : 'text-zinc-600 hover:text-zinc-900 hover:bg-zinc-100/50'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Call to action button (Desktop) -->
    <a href="/objednavka" class="hidden md:inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-zinc-900 text-white text-sm font-bold hover:bg-blue-600 transition-colors shadow-sm hover:shadow">
      Poptat web
    </a>
    
    <!-- Hamburger Menu (Mobile) -->
    <button 
      id="menu-toggle" 
      aria-label="Otevřít navigační menu" 
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="md:hidden flex flex-col justify-center items-center w-10 h-10 space-y-1.5 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 relative z-50 bg-zinc-50 rounded-full border border-zinc-200"
    >
      <span class="w-4 h-[2px] bg-zinc-900 rounded-full transition-transform duration-300 origin-center"></span>
      <span class="w-4 h-[2px] bg-zinc-900 rounded-full transition-transform duration-300 origin-center"></span>
    </button>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div 
    id="mobile-menu" 
    role="dialog"
    aria-label="Navigační menu"
    class="hidden absolute top-20 left-4 right-4 bg-white/95 backdrop-blur-xl border border-zinc-200 shadow-2xl rounded-3xl md:hidden overflow-hidden pointer-events-auto transform origin-top transition-all duration-300 opacity-0 -translate-y-4"
  >
    <nav class="flex flex-col p-4 gap-2">
      {navItems.map(item => (
        <a href={item.href} class={`mobile-link px-4 py-3 rounded-2xl text-lg font-bold transition-all ${
          currentPath === item.href
            ? 'text-zinc-900 bg-zinc-100'
            : 'text-zinc-600 hover:text-zinc-900 hover:bg-zinc-50'
        }`}>
          {item.label}
        </a>
      ))}
      <a href="/objednavka" class="mobile-link mt-2 px-4 py-4 rounded-2xl bg-zinc-900 text-white text-center text-lg font-bold hover:bg-blue-600 transition-colors">
        Poptat web
      </a>
    </nav>
  </div>
</header>

<script>
  // ─────────────────────────────────────────────────────────────────────────────
  // Module-level proměnné přežijí View Transitions — reset probíhá uvnitř
  // initMobileMenu(), které se volá při každém astro:page-load.
  //
  // PŘIDÁNO: Focus trap — klávesnicový uživatel nemůže Tab-em opustit otevřené
  // menu do pozadí stránky. Escape menu zavře a vrátí fokus na toggle button.
  // ─────────────────────────────────────────────────────────────────────────────

  let isOpen = false;
  let trapHandler: ((e: KeyboardEvent) => void) | null = null;

  function initMobileMenu() {
    const toggle = document.getElementById('menu-toggle') as HTMLButtonElement | null;
    const menu = document.getElementById('mobile-menu');
    const lines = toggle?.querySelectorAll('span');
    const links = menu?.querySelectorAll('.mobile-link');

    if (!toggle || !menu) return;

    // Odeber případný starý focus trap handler z předchozí inicializace
    if (trapHandler) {
      document.removeEventListener('keydown', trapHandler);
      trapHandler = null;
    }

    // Reset stavu při každé (re)inicializaci
    isOpen = false;
    toggle.setAttribute('aria-expanded', 'false');
    if (lines && lines.length === 2) {
      lines[0].style.transform = 'none';
      lines[1].style.transform = 'none';
    }
    menu.classList.add('hidden', 'opacity-0', '-translate-y-4');
    menu.classList.remove('opacity-100', 'translate-y-0');

    const openMenu = () => {
      isOpen = true;
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Zavřít navigační menu');
      menu.classList.remove('hidden');
      setTimeout(() => {
        menu.classList.remove('opacity-0', '-translate-y-4');
        menu.classList.add('opacity-100', 'translate-y-0');
      }, 10);
      if (lines && lines.length === 2) {
        lines[0].style.transform = 'translateY(4px) rotate(45deg)';
        lines[1].style.transform = 'translateY(-4px) rotate(-45deg)';
      }

      // ── Focus trap ──────────────────────────────────────────────────────────
      // Sesbíráme všechny focusovatelné prvky uvnitř menu (linky + případná tlačítka).
      const focusableEls = Array.from(
        menu.querySelectorAll<HTMLElement>('a[href], button:not([disabled])')
      );
      const firstEl = focusableEls[0];
      const lastEl = focusableEls[focusableEls.length - 1];

      // Přesuneme fokus na první položku menu po dokončení animace
      setTimeout(() => firstEl?.focus(), 50);

      // Odeber starý handler (bezpečnostní pojistka pro případ rychlého re-openu)
      if (trapHandler) document.removeEventListener('keydown', trapHandler);

      trapHandler = (e: KeyboardEvent) => {
        // Escape → zavři menu, vrať fokus na toggle button
        if (e.key === 'Escape') {
          closeMenu();
          toggle.focus();
          return;
        }

        // Tab → uvězni fokus uvnitř menu
        if (e.key === 'Tab') {
          if (e.shiftKey) {
            // Shift+Tab na prvním prvku → přeskočí na poslední
            if (document.activeElement === firstEl) {
              e.preventDefault();
              lastEl?.focus();
            }
          } else {
            // Tab na posledním prvku → přeskočí na první
            if (document.activeElement === lastEl) {
              e.preventDefault();
              firstEl?.focus();
            }
          }
        }
      };

      document.addEventListener('keydown', trapHandler);
    };

    const closeMenu = () => {
      isOpen = false;
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Otevřít navigační menu');
      menu.classList.remove('opacity-100', 'translate-y-0');
      menu.classList.add('opacity-0', '-translate-y-4');
      setTimeout(() => {
        menu.classList.add('hidden');
      }, 300);
      if (lines && lines.length === 2) {
        lines[0].style.transform = 'none';
        lines[1].style.transform = 'none';
      }

      // ── Odeber focus trap ───────────────────────────────────────────────────
      if (trapHandler) {
        document.removeEventListener('keydown', trapHandler);
        trapHandler = null;
      }
    };

    toggle.addEventListener('click', () => {
      isOpen ? closeMenu() : openMenu();
    });

    links?.forEach(link => {
      link.addEventListener('click', () => {
        if (isOpen) closeMenu();
      });
    });
  }

  document.addEventListener('astro:page-load', initMobileMenu);
</script>