---
// src/components/Header.astro
const navItems = [
  { label: 'Domů', href: '/' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Ceník', href: '/cenik' },
  { label: 'O mně', href: '/o-mne' },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-4 left-0 w-full z-50 px-4 pointer-events-none">
  <div class="max-w-4xl mx-auto flex items-center justify-between bg-white/80 backdrop-blur-md border border-zinc-200/50 shadow-[0_8px_30px_-10px_rgba(0,0,0,0.1)] rounded-full h-16 px-6 pointer-events-auto transition-all duration-300">
    
    <!-- Logo -->
    <a href="/" class="text-xl font-extrabold text-zinc-900 group">
      Webresent<span class="text-blue-600 transition-colors group-hover:text-blue-500">.</span>
    </a>

    <!-- Desktop Navigace -->
    <nav class="hidden md:flex items-center gap-1">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class={`px-4 py-2 rounded-full text-sm font-bold transition-all ${
            currentPath === item.href
              ? 'text-zinc-900 bg-zinc-100'
              : 'text-zinc-600 hover:text-zinc-900 hover:bg-zinc-100/50'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Call to action button (Desktop) -->
    <a href="/objednavka" class="hidden md:inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-zinc-900 text-white text-sm font-bold hover:bg-blue-600 transition-colors shadow-sm hover:shadow">
      Poptat web
    </a>
    
    <!-- Hamburger Menu (Mobile) -->
    <button id="menu-toggle" class="md:hidden flex flex-col justify-center items-center w-10 h-10 space-y-1.5 focus:outline-none relative z-50 bg-zinc-50 rounded-full border border-zinc-200" aria-label="Menu">
      <span class="w-4 h-[2px] bg-zinc-900 rounded-full transition-transform duration-300 origin-center"></span>
      <span class="w-4 h-[2px] bg-zinc-900 rounded-full transition-transform duration-300 origin-center"></span>
    </button>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden absolute top-20 left-4 right-4 bg-white/95 backdrop-blur-xl border border-zinc-200 shadow-2xl rounded-3xl md:hidden overflow-hidden pointer-events-auto transform origin-top transition-all duration-300 opacity-0 -translate-y-4">
    <nav class="flex flex-col p-4 gap-2">
      {navItems.map(item => (
        <a href={item.href} class={`mobile-link px-4 py-3 rounded-2xl text-lg font-bold transition-all ${
          currentPath === item.href
            ? 'text-zinc-900 bg-zinc-100'
            : 'text-zinc-600 hover:text-zinc-900 hover:bg-zinc-50'
        }`}>
          {item.label}
        </a>
      ))}
      <a href="/objednavka" class="mobile-link mt-2 px-4 py-4 rounded-2xl bg-zinc-900 text-white text-center text-lg font-bold hover:bg-blue-600 transition-colors">
        Poptat web
      </a>
    </nav>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const lines = toggle?.querySelectorAll('span');
    const links = menu?.querySelectorAll('.mobile-link');

    if (!toggle || !menu || toggle.dataset.init) return;
    toggle.dataset.init = 'true';

    let isOpen = false;

    const toggleMenu = () => {
      isOpen = !isOpen;
      
      if (isOpen) {
        menu.classList.remove('hidden');
        setTimeout(() => {
          menu.classList.remove('opacity-0', '-translate-y-4');
          menu.classList.add('opacity-100', 'translate-y-0');
        }, 10);
        
        if (lines && lines.length === 2) {
          lines[0].style.transform = 'translateY(4px) rotate(45deg)';
          lines[1].style.transform = 'translateY(-4px) rotate(-45deg)';
        }
      } else {
        menu.classList.remove('opacity-100', 'translate-y-0');
        menu.classList.add('opacity-0', '-translate-y-4');
        
        setTimeout(() => {
          menu.classList.add('hidden');
        }, 300);

        if (lines && lines.length === 2) {
          lines[0].style.transform = 'none';
          lines[1].style.transform = 'none';
        }
      }
    };

    toggle.addEventListener('click', toggleMenu);

    links?.forEach(link => {
      link.addEventListener('click', () => {
        if (isOpen) toggleMenu();
      });
    });
  });
</script>
