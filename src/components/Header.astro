---
// src/components/Header.astro
const navItems = [
  { label: 'Domů', href: '/' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Ceník', href: '/cenik' },
  { label: 'O mně', href: '/o-mne' },
  { label: 'Objednávka', href: '/objednavka' },
];
---

<header class="fixed top-0 left-0 w-full z-50 bg-zinc-900 border-b border-zinc-800">
  <div class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between">
    
    <a href="/" class="text-2xl font-bold text-white relative z-50">
      Webresent<span class="text-blue-500">.</span>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {navItems.map(item => (
        <a href={item.href} class="text-sm font-semibold text-zinc-300 hover:text-blue-500 transition-colors">
          {item.label}
        </a>
      ))}
    </nav>
    
    <button id="menu-toggle" class="md:hidden flex flex-col justify-center items-center w-10 h-10 space-y-1.5 focus:outline-none relative z-50" aria-label="Menu">
      <span class="w-6 h-[2px] bg-white rounded-full transition-transform duration-300 origin-center"></span>
      <span class="w-6 h-[2px] bg-white rounded-full transition-transform duration-300 origin-center"></span>
    </button>
  </div>

  <div id="mobile-menu" class="hidden absolute top-20 left-0 w-full bg-zinc-900 border-b border-zinc-800 shadow-xl md:hidden">
    <nav class="flex flex-col px-6 pb-6 pt-2">
      {navItems.map(item => (
        <a href={item.href} class="mobile-link text-xl font-semibold text-zinc-300 hover:text-blue-500 transition-colors py-4 border-b border-zinc-800 last:border-none">
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const lines = toggle?.querySelectorAll('span');
    const links = menu?.querySelectorAll('.mobile-link');

    // Pojistka, aby se skript nenačetl dvakrát
    if (!toggle || !menu || toggle.dataset.init) return;
    toggle.dataset.init = 'true';

    let isOpen = false;

    const toggleMenu = () => {
      isOpen = !isOpen;
      menu.classList.toggle('hidden');
      
      // Magie na překlopení dvou čárek do křížku
      if (lines && lines.length === 2) {
        if (isOpen) {
          lines[0].style.transform = 'translateY(4px) rotate(45deg)';
          lines[1].style.transform = 'translateY(-4px) rotate(-45deg)';
        } else {
          lines[0].style.transform = 'none';
          lines[1].style.transform = 'none';
        }
      }
    };

    toggle.addEventListener('click', toggleMenu);

    // Zavření menu po kliknutí na odkaz
    links?.forEach(link => {
      link.addEventListener('click', () => {
        if (isOpen) toggleMenu();
      });
    });
  });
</script>