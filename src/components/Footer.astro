---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();

const navItems = [
  { label: 'Domů', href: '/' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Ceník', href: '/cenik' },
  { label: 'O mně', href: '/o-mne' },
  { label: 'Objednávka', href: '/objednavka' },
];
---

<footer class="w-full bg-zinc-950 border-t border-zinc-800 mt-16 sm:mt-24 relative overflow-hidden">
  
  <!-- Velmi jemný glow na horní hraně pro eleganci -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-blue-500/50 to-transparent"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/3 h-16 bg-blue-500/5 blur-[50px] pointer-events-none"></div>

  <div class="max-w-6xl 2xl:max-w-7xl mx-auto px-6 py-12 md:py-16 relative z-10">
    
    <div class="flex flex-col md:flex-row justify-between items-center gap-10">
      
      <!-- Brand & Name -->
      <div class="flex flex-col items-center md:items-start">
        <a href="/" class="text-2xl font-extrabold text-white tracking-tight">
          Webresent<span class="text-blue-500">.</span>
        </a>
        <span class="text-sm font-semibold text-zinc-400 mt-1 tracking-wide">Bc. Jan Sodomka</span>
      </div>

      <!-- Horizontal Nav -->
      <nav class="flex flex-wrap justify-center gap-x-8 gap-y-4">
        {navItems.map(item => (
          <a href={item.href} class="text-sm font-semibold text-zinc-400 hover:text-white transition-colors duration-300 relative group">
            {item.label}
            <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-blue-500 transition-all duration-300 group-hover:w-full rounded-full"></span>
          </a>
        ))}
      </nav>

      <!-- Contact -->
      <div class="flex items-center">
        <a href="mailto:h.sodomka@seznam.cz" class="inline-flex items-center gap-2.5 px-6 py-3 rounded-full bg-zinc-900 border border-zinc-800 text-sm font-bold text-zinc-300 hover:border-blue-500 hover:text-white hover:bg-zinc-800 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300">
          <svg class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
          h.sodomka@seznam.cz
        </a>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-zinc-800/80 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs font-medium text-zinc-500">
      <p>&copy; {currentYear} Webresent. Všechna práva vyhrazena.</p>
      <div class="flex gap-6">
        <a href="/ochrana-udaju" class="hover:text-zinc-300 transition-colors duration-300">Ochrana osobních údajů</a>
        <a href="/obchodni-podminky" class="hover:text-zinc-300 transition-colors duration-300">Obchodní podmínky</a>
      </div>
    </div>

  </div>
</footer>