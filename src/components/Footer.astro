---
const year = new Date().getFullYear();
const nav = [
  { label: 'Portfolio',   href: '/portfolio' },
  { label: 'Ceník',      href: '/cenik' },
  { label: 'O mně',      href: '/o-mne' },
  { label: 'Objednávka', href: '/objednavka' },
];
---

<footer class="sf">
  <!-- Big wordmark -->
  <div class="sf__wordmark" aria-hidden="true">Webresent</div>

  <div class="sf__inner">
    <div class="sf__top">
      <div>
        <a href="/" class="sf__logo">Webresent</a>
        <p class="sf__claim">Weby, které vydělávají.</p>
      </div>
      <nav class="sf__nav" aria-label="Patouční navigace">
        {nav.map(item => (
          <a href={item.href} class="sf__nav-link">{item.label}</a>
        ))}
      </nav>
      <div class="sf__contact">
        <a href="mailto:info@webresent.cz" class="sf__contact-link">info@webresent.cz</a>
        <a href="tel:+420604994883" class="sf__contact-link">+420 604 994 883</a>
      </div>
    </div>

    <div class="sf__bottom">
      <span>&copy; {year} Webresent &mdash; Bc. Jan Sodomka</span>
      <div class="sf__legal">
        <a href="/ochrana-udaju">Ochrana údajů</a>
        <a href="/obchodni-podminky">Obchodní podmínky</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .sf {
    border-top: 1px solid var(--c-border);
    background: var(--c-bg-soft);
    position: relative; overflow: hidden;
  }
  .sf__wordmark {
    font-family: var(--f-serif); font-style: italic; font-weight: 700;
    font-size: clamp(5rem, 16vw, 14rem);
    color: transparent;
    -webkit-text-stroke: 1px var(--c-border);
    letter-spacing: -0.04em; line-height: 1;
    padding: 2rem 2.5rem 0;
    pointer-events: none; user-select: none;
    white-space: nowrap; overflow: hidden;
  }
  .sf__inner {
    max-width: 1280px; margin: 0 auto; padding: 2rem 2.5rem 0;
  }
  .sf__top {
    display: grid; grid-template-columns: 1fr auto auto; gap: 4rem; align-items: start;
    padding-bottom: 3rem; border-bottom: 1px solid var(--c-border);
  }
  .sf__logo {
    font-family: var(--f-serif); font-style: italic; font-weight: 700;
    font-size: 1.1rem; color: var(--c-ink); text-decoration: none; display: block; margin-bottom: .4rem;
    transition: opacity .2s;
  }
  .sf__logo:hover { opacity: .5; }
  .sf__claim { font-size: .85rem; color: var(--c-ink-soft); }
  .sf__nav { display: flex; flex-direction: column; gap: .55rem; }
  .sf__nav-link {
    font-size: .75rem; font-weight: 600; letter-spacing: .1em; text-transform: uppercase;
    color: var(--c-ink-mid); text-decoration: none; transition: color .2s;
  }
  .sf__nav-link:hover { color: var(--c-ink); }
  .sf__contact { display: flex; flex-direction: column; gap: .55rem; align-items: flex-end; }
  .sf__contact-link {
    font-size: .875rem; font-weight: 500; color: var(--c-ink-mid);
    text-decoration: none; transition: color .2s;
  }
  .sf__contact-link:hover { color: var(--c-red); }
  .sf__bottom {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.5rem 0; font-size: .72rem; font-weight: 500;
    color: var(--c-ink-soft); flex-wrap: wrap; gap: 1rem;
  }
  .sf__legal { display: flex; gap: 2rem; }
  .sf__legal a { color: var(--c-ink-soft); text-decoration: none; transition: color .2s; }
  .sf__legal a:hover { color: var(--c-ink); }

  @media (max-width: 768px) {
    .sf__top { grid-template-columns: 1fr; gap: 2.5rem; }
    .sf__contact { align-items: flex-start; }
    .sf__bottom { flex-direction: column; align-items: flex-start; }
    .sf__inner { padding: 2rem 1.5rem 0; }
    .sf__wordmark { padding: 2rem 1.5rem 0; }
  }
</style>
