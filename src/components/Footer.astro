---
const year = new Date().getFullYear();
const nav = [
  { label: 'Domů',       href: '/' },
  { label: 'Portfolio',  href: '/portfolio' },
  { label: 'Ceník',      href: '/cenik' },
  { label: 'O mně',      href: '/o-mne' },
  { label: 'Objednávka', href: '/objednavka' },
];
const p = Astro.url.pathname;
---

<footer class="f">
  <div class="f__inner">

    <div class="f__top">
      <div class="f__brand">
        <a href="/" class="f__logo">Webresent</a>
        <p class="f__claim">Web, který vás reprezentuje.</p>
      </div>
      <div class="f__contact">
        <a href="mailto:info@webresent.cz" class="f__link">info@webresent.cz</a>
        <a href="tel:+420604994883" class="f__link">+420 604 994 883</a>
      </div>
    </div>

    <div class="f__mid">
      <nav class="f__nav" aria-label="Patčka navigace">
        {nav.map(item => (
          <a href={item.href} class={`f__nav-a${p === item.href ? ' f__nav-a--on' : ''}`}>
            {item.label}
          </a>
        ))}
      </nav>
    </div>

    <div class="f__bottom">
      <span>&copy; {year} Bc. Jan Sodomka &mdash; Webresent</span>
      <div class="f__legal">
        <a href="/ochrana-udaju" class="f__legal-a">Ochrana údajů</a>
        <a href="/obchodni-podminky" class="f__legal-a">Obchodní podmínky</a>
      </div>
    </div>

  </div>
</footer>

<style>
.f {
  border-top: 1px solid var(--line);
  background: var(--bg);
}

.f__inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 3.5rem 2.5rem 2rem;
}

.f__top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 2rem;
  padding-bottom: 2.5rem;
  border-bottom: 1px solid var(--line);
}

.f__logo {
  font-size: 1.05rem;
  font-weight: 800;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--white);
  text-decoration: none;
  display: block;
  margin-bottom: .6rem;
  transition: opacity .2s;
}
.f__logo:hover { opacity: .4; }

.f__claim {
  font-size: .78rem;
  color: var(--white-3);
  letter-spacing: .02em;
}

.f__contact {
  display: flex;
  flex-direction: column;
  gap: .4rem;
  align-items: flex-end;
}

.f__link {
  font-size: .78rem;
  font-weight: 500;
  color: var(--white-2);
  text-decoration: none;
  transition: color .2s;
}
.f__link:hover { color: var(--white); }

.f__mid {
  padding: 2rem 0;
  border-bottom: 1px solid var(--line);
}

.f__nav {
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
}

.f__nav-a {
  font-size: .72rem;
  font-weight: 600;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--white-3);
  text-decoration: none;
  transition: color .2s;
}
.f__nav-a:hover { color: var(--white); }
.f__nav-a--on { color: var(--white); }

.f__bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 1.8rem;
  font-size: .7rem;
  color: var(--white-3);
  flex-wrap: wrap;
  gap: 1rem;
}

.f__legal {
  display: flex;
  gap: 1.8rem;
}

.f__legal-a {
  font-size: .7rem;
  color: var(--white-3);
  text-decoration: none;
  transition: color .2s;
}
.f__legal-a:hover { color: var(--white); }

@media (max-width: 640px) {
  .f__inner { padding: 2.5rem 1.5rem 1.5rem; }
  .f__top { flex-direction: column; }
  .f__contact { align-items: flex-start; }
  .f__bottom { flex-direction: column; align-items: flex-start; }
  .f__nav { gap: 1.4rem; }
}
</style>
