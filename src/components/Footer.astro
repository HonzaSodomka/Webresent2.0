---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();

const navItems = [
  { label: 'Domů', href: '/' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Ceník', href: '/cenik' },
  { label: 'O mně', href: '/o-mne' },
  { label: 'Objednávka', href: '/objednavka' },
];
---

<footer class="bg-zinc-900 text-zinc-400 py-12 border-t border-zinc-800 mt-20">
  <div class="max-w-6xl 2xl:max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      
      <!-- Brand a popisek -->
      <div class="flex flex-col items-start">
        <a href="/" class="text-2xl font-bold text-white mb-4">
          Webresent<span class="text-blue-500">.</span>
        </a>
        <p class="text-zinc-400 text-sm leading-relaxed max-w-xs">
          Stavím prémiové weby na míru. Blesková rychlost, čistý kód a důraz na to nejdůležitější – váš zisk.
        </p>
      </div>

      <!-- Navigace -->
      <div>
        <h3 class="text-white font-bold mb-4">Navigace</h3>
        <ul class="space-y-2">
          {navItems.map(item => (
            <li>
              <a href={item.href} class="text-sm hover:text-white transition-colors duration-200">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Kontakt -->
      <div>
        <h3 class="text-white font-bold mb-4">Kontakt</h3>
        <ul class="space-y-2">
          <li>
            <a href="mailto:info@webresent.cz" class="text-sm hover:text-white transition-colors duration-200 flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
              info@webresent.cz
            </a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Spodní lišta -->
    <div class="pt-8 border-t border-zinc-800 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs">
      <p>&copy; {currentYear} Webresent. Všechna práva vyhrazena.</p>
      <div class="flex gap-4">
        <a href="/ochrana-udaju" class="hover:text-white transition-colors">Ochrana údajů</a>
        <a href="/obchodni-podminky" class="hover:text-white transition-colors">Obchodní podmínky</a>
      </div>
    </div>
  </div>
</footer>