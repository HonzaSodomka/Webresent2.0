---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();

const navItems = [
  { label: 'Domů', href: '/' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Ceník', href: '/cenik' },
  { label: 'O mně', href: '/o-mne' },
  { label: 'Objednávka', href: '/objednavka' },
];
---

<div class="w-full flex justify-center px-4 sm:px-6 md:px-10 pb-4 sm:pb-6 md:pb-8">
  <footer class="w-full bg-zinc-900 border border-zinc-800 rounded-[2rem] shadow-xl overflow-hidden">
    <div class="max-w-6xl 2xl:max-w-7xl mx-auto px-6 py-8 sm:px-10">
      
      <div class="flex flex-col md:flex-row justify-between items-center gap-6">
        
        <!-- Brand & Name -->
        <div class="flex flex-col items-center md:items-start">
          <a href="/" class="text-xl font-bold text-white">
            Webresent<span class="text-blue-500">.</span>
          </a>
          <span class="text-sm font-bold text-zinc-400 mt-0.5 tracking-wide">Bc. Jan Sodomka</span>
        </div>

        <!-- Horizontal Nav -->
        <nav class="flex flex-wrap justify-center gap-x-8 gap-y-3">
          {navItems.map(item => (
            <a href={item.href} class="text-sm font-semibold text-zinc-400 hover:text-white transition-colors">
              {item.label}
            </a>
          ))}
        </nav>

        <!-- Contact -->
        <div class="flex flex-col items-center md:items-end gap-2">
          <a href="mailto:info@webresent.cz" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-zinc-800 border border-zinc-700 text-sm font-bold text-zinc-300 hover:border-blue-500 hover:text-white hover:bg-zinc-700 hover:shadow-sm hover:-translate-y-0.5 transition-all duration-300">
            <svg class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            info@webresent.cz
          </a>
          <a href="tel:+420604994883" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-zinc-800 border border-zinc-700 text-sm font-bold text-zinc-300 hover:border-blue-500 hover:text-white hover:bg-zinc-700 hover:shadow-sm hover:-translate-y-0.5 transition-all duration-300">
            <svg class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            604 994 883
          </a>
        </div>

      </div>

      <!-- Bottom bar -->
      <div class="mt-8 pt-6 border-t border-zinc-800 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs font-medium text-zinc-500">
        <div class="flex items-center gap-4">
          <p>&copy; {currentYear} Webresent. Všechna práva vyhrazena.</p>
          <span class="hidden sm:block text-zinc-700">·</span>
          <span class="hidden sm:block text-zinc-600">IČO: <span class="text-zinc-500">doplňuji</span></span>
        </div>
        <div class="flex gap-6">
          <a href="/ochrana-udaju" class="hover:text-zinc-300 transition-colors">Ochrana údajů</a>
          <a href="/obchodni-podminky" class="hover:text-zinc-300 transition-colors">Obchodní podmínky</a>
        </div>
      </div>

    </div>
  </footer>
</div>