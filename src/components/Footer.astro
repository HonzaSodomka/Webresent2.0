---
const currentYear = new Date().getFullYear();
const navItems = [
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Ceník', href: '/cenik' },
  { label: 'O mně', href: '/o-mne' },
  { label: 'Objednávka', href: '/objednavka' },
];
---

<footer class="site-footer">
  <div class="site-footer__inner">

    <div class="site-footer__top">
      <div class="site-footer__brand">
        <a href="/" class="site-footer__logo">Webresent</a>
        <p class="site-footer__tagline">Weby, které vydělávají.</p>
      </div>

      <nav class="site-footer__nav" aria-label="Navigace patou">
        {navItems.map(item => (
          <a href={item.href} class="site-footer__nav-link">{item.label}</a>
        ))}
      </nav>

      <div class="site-footer__contact">
        <a href="mailto:info@webresent.cz" class="site-footer__contact-link">
          info@webresent.cz
        </a>
        <a href="tel:+420604994883" class="site-footer__contact-link">
          +420 604 994 883
        </a>
      </div>
    </div>

    <div class="site-footer__bottom">
      <span>&copy; {currentYear} Webresent &mdash; Bc. Jan Sodomka</span>
      <div class="site-footer__legal">
        <a href="/ochrana-udaju">Ochrana údajů</a>
        <a href="/obchodni-podminky">Obchodní podmínky</a>
      </div>
    </div>

  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid #e4e4e4;
    background: #f9f9f7;
    margin-top: 0;
  }
  .site-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .site-footer__top {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 4rem;
    align-items: start;
    padding: 4rem 0 3rem;
    border-bottom: 1px solid #e4e4e4;
  }
  .site-footer__logo {
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #111;
    text-decoration: none;
    display: block;
    margin-bottom: 0.5rem;
  }
  .site-footer__logo:hover { opacity: 0.6; }
  .site-footer__tagline {
    font-size: 0.85rem;
    color: #888;
    font-weight: 400;
  }
  .site-footer__nav {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .site-footer__nav-link {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #666;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .site-footer__nav-link:hover { color: #111; }
  .site-footer__contact {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    align-items: flex-end;
  }
  .site-footer__contact-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: #555;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .site-footer__contact-link:hover { color: #111; }

  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
    font-size: 0.75rem;
    font-weight: 500;
    color: #999;
    letter-spacing: 0.04em;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .site-footer__legal {
    display: flex;
    gap: 2rem;
  }
  .site-footer__legal a {
    color: #999;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .site-footer__legal a:hover { color: #111; }

  @media (max-width: 768px) {
    .site-footer__top {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 3rem 0 2.5rem;
    }
    .site-footer__contact { align-items: flex-start; }
    .site-footer__bottom { flex-direction: column; align-items: flex-start; }
  }
  @media (max-width: 600px) {
    .site-footer__inner { padding: 0 1.25rem; }
  }
</style>
