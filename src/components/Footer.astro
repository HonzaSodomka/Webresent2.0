---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();

const navItems = [
  { label: 'Domů', href: '/' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Ceník', href: '/cenik' },
  { label: 'O mně', href: '/o-mne' },
  { label: 'Objednávka', href: '/objednavka' },
];
---

<footer class="w-full bg-zinc-950 border-t border-zinc-800/80 mt-16 sm:mt-24 relative overflow-hidden flex flex-col items-center">
  
  <!-- Subtle Grid Pattern & Top Glow -->
  <div class="absolute inset-0 opacity-[0.02] pointer-events-none" style="background-image: radial-gradient(circle at center, #ffffff 1px, transparent 1px); background-size: 24px 24px;"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[80%] max-w-3xl h-px bg-gradient-to-r from-transparent via-blue-500/40 to-transparent"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-24 bg-blue-500/10 blur-[80px] pointer-events-none"></div>

  <div class="w-full max-w-6xl 2xl:max-w-7xl mx-auto px-6 pt-16 pb-8 relative z-10 flex flex-col">
    
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start mb-10">
      
      <!-- Brand & Mission (Left - spans 5 cols) -->
      <div class="flex flex-col items-start md:col-span-5">
        <a href="/" class="text-2xl font-extrabold text-white tracking-tight flex items-center gap-2">
          <div class="w-6 h-6 rounded-full bg-blue-600 flex items-center justify-center">
            <div class="w-2 h-2 bg-white rounded-full"></div>
          </div>
          Webresent
        </a>
        <p class="text-sm font-medium text-zinc-500 mt-5 leading-relaxed max-w-sm">
          Nestavím obyčejné šablony. Navrhuji a programuji bleskově rychlé, prémiové weby na míru, které budují důvěru a reálně prodávají.
        </p>
      </div>

      <!-- Nav (Center - spans 3 cols) -->
      <nav class="flex flex-col items-start md:col-span-3">
        <span class="text-xs font-bold text-zinc-600 uppercase tracking-wider mb-5">Navigace</span>
        <ul class="flex flex-col gap-3">
          {navItems.map(item => (
            <li>
              <a href={item.href} class="text-sm font-semibold text-zinc-400 hover:text-white transition-colors duration-300 flex items-center gap-2 group">
                <span class="w-0 h-[1px] bg-blue-500 transition-all duration-300 group-hover:w-3"></span>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact & Status (Right - spans 4 cols) -->
      <div class="flex flex-col items-start md:items-end md:col-span-4 md:text-right">
         <span class="text-xs font-bold text-zinc-600 uppercase tracking-wider mb-5">Zahájit spolupráci</span>
         
         <a href="mailto:h.sodomka@seznam.cz" class="group flex items-center gap-3 text-zinc-300 hover:text-white transition-colors mb-6">
            <div class="w-10 h-10 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center group-hover:border-blue-500 group-hover:bg-blue-500/10 transition-all duration-300">
              <svg class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            </div>
            <span class="font-bold text-sm tracking-wide">h.sodomka@seznam.cz</span>
         </a>

         <div class="inline-flex items-center gap-2.5 px-3 py-1.5 rounded-full bg-zinc-900/50 border border-zinc-800/80">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
            </span>
            <span class="text-[11px] font-bold text-zinc-400 uppercase tracking-wider">Dostupný pro nové projekty</span>
         </div>
      </div>
    </div>

    <!-- Massive Typography (The "Awwwards" trick) -->
    <div class="w-full flex justify-center py-6 sm:py-8 select-none pointer-events-none opacity-[0.025] overflow-hidden">
      <span class="text-[14vw] leading-[0.8] font-black text-white tracking-tighter whitespace-nowrap">WEBRESENT</span>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-zinc-800/60 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs font-medium text-zinc-600">
      <p>&copy; {currentYear} Bc. Jan Sodomka. Všechna práva vyhrazena.</p>
      <div class="flex gap-6">
        <a href="/ochrana-udaju" class="hover:text-zinc-300 transition-colors duration-300">Ochrana osobních údajů</a>
        <a href="/obchodni-podminky" class="hover:text-zinc-300 transition-colors duration-300">Obchodní podmínky</a>
      </div>
    </div>

  </div>
</footer>