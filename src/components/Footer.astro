---
const year = new Date().getFullYear();
---
<footer class="f">
  <div class="f__top">
    <div class="f__left">
      <a href="/" class="f__logo">WR</a>
      <p class="f__claim">Weby které vydělávají.</p>
    </div>
    <div class="f__right">
      <a href="mailto:info@webresent.cz" class="f__link">info@webresent.cz</a>
      <a href="tel:+420604994883" class="f__link">+420 604 994 883</a>
    </div>
  </div>

  <div class="f__mid">
    <nav class="f__nav">
      <a href="/" class="f__nav-a">Domů</a>
      <a href="/portfolio" class="f__nav-a">Portfolio</a>
      <a href="/cenik" class="f__nav-a">Ceník</a>
      <a href="/o-mne" class="f__nav-a">O mně</a>
      <a href="/objednavka" class="f__nav-a">Objednávka</a>
    </nav>
  </div>

  <div class="f__bottom">
    <span>&copy; {year} Bc. Jan Sodomka &mdash; Webresent</span>
    <div class="f__legal">
      <a href="/ochrana-udaju">Ochrana údajů</a>
      <a href="/obchodni-podminky">Obchodní podmínky</a>
    </div>
  </div>
</footer>

<style>
.f {
  border-top: 1px solid var(--line);
  background: var(--bg);
  max-width: 1400px; margin: 0 auto;
  padding: 4rem 2.5rem 2.5rem;
}
.f__top {
  display: flex; justify-content: space-between; align-items: flex-start;
  padding-bottom: 3rem; border-bottom: 1px solid var(--line);
  gap: 2rem;
}
.f__logo {
  font-size: .75rem; font-weight: 800; letter-spacing: .2em;
  color: var(--white); text-decoration: none; display: block; margin-bottom: .75rem;
  transition: opacity .2s;
}
.f__logo:hover { opacity: .4; }
.f__claim { font-size: .85rem; color: var(--white-3); }
.f__right { display: flex; flex-direction: column; gap: .5rem; align-items: flex-end; }
.f__link {
  font-size: .85rem; font-weight: 500; color: var(--white-2);
  text-decoration: none; transition: color .2s;
}
.f__link:hover { color: var(--white); }

.f__mid {
  padding: 2.5rem 0; border-bottom: 1px solid var(--line);
}
.f__nav { display: flex; gap: 2.5rem; flex-wrap: wrap; }
.f__nav-a {
  font-size: .72rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase;
  color: var(--white-3); text-decoration: none; transition: color .2s;
}
.f__nav-a:hover { color: var(--white); }

.f__bottom {
  display: flex; justify-content: space-between; align-items: center;
  padding-top: 2rem; font-size: .72rem; color: var(--white-3);
  flex-wrap: wrap; gap: 1rem;
}
.f__legal { display: flex; gap: 2rem; }
.f__legal a { color: var(--white-3); text-decoration: none; transition: color .2s; }
.f__legal a:hover { color: var(--white); }

@media (max-width: 640px) {
  .f { padding: 3rem 1.5rem 2rem; }
  .f__top { flex-direction: column; }
  .f__right { align-items: flex-start; }
  .f__bottom { flex-direction: column; align-items: flex-start; }
}
</style>
