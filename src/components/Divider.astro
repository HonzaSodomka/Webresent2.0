---
const { label = '' } = Astro.props;
---
<div class="d" aria-hidden="true">
  {label && <span class="d__l">{label}</span>}
</div>
<style>
.d {
  width: 100%; height: 1px; background: var(--line);
  margin: 7rem 0; position: relative;
}
.d__l {
  position: absolute; top: 50%; left: 0; transform: translateY(-50%);
  font-size: .65rem; font-weight: 600; letter-spacing: .16em; text-transform: uppercase;
  color: var(--white-3); background: var(--bg); padding-right: 1.2rem;
}
</style>
